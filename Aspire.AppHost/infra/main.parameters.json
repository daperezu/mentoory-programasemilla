{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "principalId": {
        "value": "${AZURE_PRINCIPAL_ID}"
      },
      "googleanalytics_enabled": {
        "value": "${AZURE_GOOGLEANALYTICS_ENABLED}"
      },
      "googleanalytics_measurementid": {
        "value": "${AZURE_GOOGLEANALYTICS_MEASUREMENTID}"
      },
      "mailgun_apikey": {
        "value": "${AZURE_MAILGUN_APIKEY}"
      },
      "mailgun_domain": {
        "value": "${AZURE_MAILGUN_DOMAIN}"
      },
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      }
    }
  }
  