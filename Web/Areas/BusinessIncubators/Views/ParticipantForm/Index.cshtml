@model LinaSys.Web.Areas.BusinessIncubators.Models.ParticipantForm.ParticipantFormViewModel
@{
    ViewData["Title"] = "Completar Formulario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* Choices.js custom styling for better visibility */
        .choices__list--dropdown {
            background-color: var(--phoenix-body-bg);
            border: 1px solid var(--phoenix-border-color);
            max-height: 300px !important;
            z-index: 9999 !important;
        }
        
        .choices__list--dropdown .choices__item {
            color: var(--phoenix-body-color) !important;
            padding: 10px !important;
            font-size: 0.9rem;
        }
        
        .choices__list--dropdown .choices__item--selectable {
            background-color: var(--phoenix-body-bg);
        }
        
        .choices__list--dropdown .choices__item--selectable.is-highlighted {
            background-color: var(--phoenix-primary-bg-subtle) !important;
            color: var(--phoenix-primary) !important;
        }
        
        .choices__input {
            background-color: var(--phoenix-body-bg) !important;
            color: var(--phoenix-body-color) !important;
            border: none !important;
            padding: 8px !important;
        }
        
        .choices__inner {
            background-color: var(--phoenix-input-bg) !important;
            border-color: var(--phoenix-input-border-color) !important;
            min-height: 38px !important;
        }
        
        .choices.is-open .choices__inner {
            border-color: var(--phoenix-primary) !important;
        }
        
        .choices.is-open .choices__list--dropdown {
            border-color: var(--phoenix-primary) !important;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }
        
        /* Ensure dropdown appears above when at bottom of viewport */
        .choices__list.choices__list--dropdown.is-active {
            visibility: visible !important;
        }
        
        /* Add extra padding for question cards with dropdowns */
        .form-question:has(.choices.is-open) {
            padding-bottom: 250px !important;
            transition: padding-bottom 0.3s ease;
        }
        
        /* Dark mode support */
        [data-bs-theme="dark"] .choices__list--dropdown {
            background-color: var(--phoenix-gray-900);
            border-color: var(--phoenix-gray-700);
        }
        
        [data-bs-theme="dark"] .choices__list--dropdown .choices__item {
            color: var(--phoenix-gray-100) !important;
        }
        
        [data-bs-theme="dark"] .choices__list--dropdown .choices__item--selectable.is-highlighted {
            background-color: rgba(var(--phoenix-primary-rgb), 0.2) !important;
            color: var(--phoenix-primary-light) !important;
        }
        
        [data-bs-theme="dark"] .choices__input {
            background-color: var(--phoenix-gray-900) !important;
            color: var(--phoenix-gray-100) !important;
        }
        
        [data-bs-theme="dark"] .choices__inner {
            background-color: var(--phoenix-gray-900) !important;
            border-color: var(--phoenix-gray-700) !important;
            color: var(--phoenix-gray-100) !important;
        }
        .wizard-container {
            min-height: calc(100vh - 200px);
        }

        .wizard-nav {
            position: sticky;
            top: 20px;
            max-height: calc(100vh - 100px);
            overflow-y: auto;
        }

        .wizard-nav .nav-link {
            display: flex;
            align-items: center;
            padding: 0.75rem 1rem;
            margin-bottom: 0.5rem;
            border-radius: 0.375rem;
            transition: all 0.2s;
        }

        .wizard-nav .nav-link:hover {
            background-color: var(--phoenix-gray-100);
        }

        .wizard-nav .nav-link.active {
            background-color: var(--phoenix-primary);
            color: white;
        }

        .wizard-nav .nav-link.completed {
            color: var(--phoenix-success);
        }

        .nav-item-circle-parent {
            margin-right: 0.75rem;
        }

        .nav-item-circle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2rem;
            height: 2rem;
            border-radius: 50%;
            background-color: var(--phoenix-gray-200);
            font-weight: 600;
            font-size: 0.875rem;
        }

        .nav-link.active .nav-item-circle {
            background-color: rgba(255, 255, 255, 0.2);
            color: white;
        }

        .nav-link.completed .nav-item-circle {
            background-color: var(--phoenix-success);
            color: white;
        }

        /* All progress styles moved to linasys.css */

        .form-question {
            margin-bottom: 2rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid var(--phoenix-gray-200);
        }

        .form-question:last-child {
            border-bottom: none;
        }

        .question-label {
            font-weight: 600;
            margin-bottom: 0.5rem;
            display: block;
        }

        .question-required {
            color: var(--phoenix-danger);
            font-weight: normal;
        }

        .question-help {
            font-size: 0.875rem;
            color: var(--phoenix-gray-600);
            margin-top: 0.25rem;
        }

        .auto-save-indicator {
            position: fixed;
            bottom: 20px;
            right: 20px;
            padding: 0.5rem 1rem;
            background-color: var(--phoenix-gray-900);
            color: white;
            border-radius: 0.375rem;
            font-size: 0.875rem;
            display: none;
            align-items: center;
            gap: 0.5rem;
            z-index: 1050;
        }

        .auto-save-indicator.show {
            display: flex;
        }

        .auto-save-indicator.saving {
            background-color: var(--phoenix-info);
        }

        .auto-save-indicator.saved {
            background-color: var(--phoenix-success);
        }

        .auto-save-indicator.error {
            background-color: var(--phoenix-danger);
        }

        @@media (max-width: 768px) {
            .wizard-nav {
                position: fixed;
                bottom: 0;
                left: 0;
                right: 0;
                max-height: 200px;
                background-color: white;
                border-top: 1px solid var(--phoenix-gray-200);
                z-index: 1040;
                padding: 1rem;
            }

            .wizard-nav .nav {
                flex-direction: row !important;
                overflow-x: auto;
                flex-wrap: nowrap;
            }

            .wizard-nav .nav-link {
                white-space: nowrap;
                margin-right: 0.5rem;
                margin-bottom: 0;
            }

            .main-content {
                padding-bottom: 220px;
            }
        }
        /* Feedback Styles */
        .feedback-conversation {
            border-left: 3px solid var(--phoenix-warning);
            margin-bottom: 1rem;
        }
        
        .feedback-conversation.feedback-closed {
            border-left-color: var(--phoenix-success);
            opacity: 0.9;
        }
        
        .feedback-message {
            position: relative;
            border-left: 2px solid transparent;
        }
        
        .feedback-message.bg-primary-subtle {
            background-color: var(--phoenix-primary-bg-subtle) !important;
            border-left-color: var(--phoenix-primary);
        }
        
        .feedback-message.bg-warning-subtle {
            background-color: var(--phoenix-warning-bg-subtle) !important;
            border-left-color: var(--phoenix-warning);
        }
        
        .feedback-author {
            font-size: 0.875rem;
            color: var(--phoenix-gray-700);
        }
        
        .feedback-content {
            color: var(--phoenix-body-color);
        }
        
        .feedback-actions .input-group {
            max-width: 100%;
        }
        
        /* Question with feedback indicator */
        .form-question.has-feedback {
            position: relative;
            padding-left: 1rem;
            border-left: 4px solid var(--phoenix-warning);
            background: linear-gradient(90deg, var(--phoenix-warning-bg-subtle) 0%, transparent 5%);
        }
        
        .form-question.has-feedback.feedback-resolved {
            border-left-color: var(--phoenix-success);
            background: linear-gradient(90deg, var(--phoenix-success-bg-subtle) 0%, transparent 5%);
        }
    </style>
}

<div class="container-fluid wizard-container" id="wizardContainer" style="display: none;">
    <div class="row">
        <!-- Progress Bar -->
        <div class="col-12">
            <div class="d-flex align-items-center mb-3">
                <div class="progress-wrapper flex-grow-1">
                    <div class="progress">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 0%" id="progressBar"></div>
                    </div>
                    <!-- Tick marks -->
                    <div class="progress-ticks">
                        <span class="tick" style="left: 0%"></span>
                        <span class="tick" style="left: 25%"></span>
                        <span class="tick" style="left: 50%"></span>
                        <span class="tick" style="left: 75%"></span>
                        <span class="tick" style="left: 100%"></span>
                    </div>
                </div>
                <div class="ms-3">
                    <span class="progress-percentage badge bg-primary" id="progressPercentage">0%</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Sidebar Navigation -->
        <div class="col-lg-3 col-md-4">
            <div class="wizard-nav" id="wizardNav">
                <div class="nav nav-pills flex-column" id="blockNavigation">
                    <!-- Blocks will be loaded here dynamically -->
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9 col-md-8 main-content">
            @* Feedback Summary Alert *@
            @if (Model.FeedbackConversations.Any())
            {
                var openCount = Model.FeedbackConversations.Count(f => f.Status == LinaSys.BusinessIncubator.Domain.Enums.FeedbackStatus.ReviewNeeded);
                var closedCount = Model.FeedbackConversations.Count(f => f.Status == LinaSys.BusinessIncubator.Domain.Enums.FeedbackStatus.ReviewClosed);
                
                if (openCount > 0)
                {
                    <div class="alert alert-warning mb-3" role="alert">
                        <i class="fas fa-comment-dots me-2"></i>
                        <strong>Tienes retroalimentación del coordinador:</strong>
                        <span class="badge bg-warning ms-2">@openCount Requiere Revisión</span>
                        @if (closedCount > 0)
                        {
                            <span class="badge bg-success ms-2">@closedCount Cerrados</span>
                        }
                        <div class="mt-2 small">
                            <i class="fas fa-info-circle"></i> La retroalimentación aparece junto a cada pregunta correspondiente.
                        </div>
                    </div>
                }
            }
            
            <div class="form-card phoenix-card">
                <div class="card-header phoenix-gradient d-flex justify-content-between align-items-center">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-clipboard-list me-2"></i>
                        <span id="blockTitle">Cargando formulario...</span>
                    </h3>
                    <span class="badge bg-white text-primary" id="blockBadge">
                        Bloque <span id="currentBlockNum">1</span> de <span id="totalBlocksNum">1</span>
                    </span>
                </div>
                <div class="card-body" id="formContent">
                    <!-- Form blocks will be loaded here -->
                    <!-- Feedback will be injected inline by JavaScript -->
                </div>
                
                <!-- Action Buttons -->
                <div class="card-footer bg-light">
                    <div class="d-flex justify-content-between align-items-center" id="actionButtons" style="display: none !important;">
                        <button class="btn btn-falcon-default" id="btnPrevious" disabled>
                            <i class="fas fa-chevron-left me-1"></i> Anterior
                        </button>
                        <div>
                            <button class="btn btn-light me-2" id="btnSaveDraft">
                                <i class="fas fa-save me-1"></i> Guardar Borrador
                            </button>
                            <button class="btn btn-primary" id="btnNext">
                                Siguiente <i class="fas fa-chevron-right ms-1"></i>
                            </button>
                            <button class="btn btn-success" id="btnSubmit" style="display: none;">
                                <i class="fas fa-paper-plane me-1"></i> Enviar Formulario
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loading Spinner -->
<div class="form-loading-container" id="formLoadingContainer">
    <div class="text-center">
        <div class="form-loading-spinner"></div>
        <div class="form-loading-text">Cargando formulario...</div>
    </div>
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <!-- Choices.js for enhanced selects -->
    <link href="~/vendors/choices/choices.min.css" rel="stylesheet" />
    <script src="~/vendors/choices/choices.min.js"></script>
    
    <script>
        // Configuration
        const config = {
            businessIncubatorId: '@Model.BusinessIncubatorExternalId',
            projectId: '@Model.ProjectExternalId',
            projectIdNumeric: @Model.ProjectId,
            submissionId: @(Model.SubmissionId?.ToString() ?? "null"),
            canSubmit: @(Model.CanSubmit ? "true" : "false"),
            isReadOnly: @(Model.IsReadOnly ? "true" : "false"),
            feedbackReadOnly: @(Model.FeedbackReadOnly ? "true" : "false")
        };

        // Initial draft data
        let draftData = @Html.Raw(Model.DraftData != null ? System.Text.Json.JsonSerializer.Serialize(Model.DraftData, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }) : "null");
        
        // Feedback data for inline display
        const feedbackData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FeedbackConversations, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
    </script>
    
    <!-- Feedback progressive enhancement -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Handle feedback form submissions with AJAX
            document.addEventListener('submit', function(e) {
                const form = e.target;
                
                // Check if it's a feedback form
                if (form.classList.contains('feedback-reply-form') || 
                    form.action.includes('ReplyToFeedback') ||
                    form.action.includes('CloseFeedback') || 
                    form.action.includes('ReopenFeedback')) {
                    
                    e.preventDefault();
                    
                    const formData = new FormData(form);
                    const submitButton = form.querySelector('button[type="submit"]');
                    
                    // Disable button during submission
                    if (submitButton) {
                        submitButton.disabled = true;
                    }
                    
                    // Send AJAX request
                    fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        },
                        body: formData
                    })
                    .then(response => {
                        if (!response.ok) throw new Error('Network response was not ok');
                        return response.text();
                    })
                    .then(html => {
                        // Check if response is JSON (for close/reopen actions)
                        try {
                            const json = JSON.parse(html);
                            if (json.success) {
                                // Reload the page to show updated status
                                window.location.reload();
                            }
                        } catch {
                            // Response is HTML (partial view for reply)
                            const feedbackId = formData.get('parentFeedbackId') || formData.get('feedbackId');
                            const feedbackElement = document.querySelector(`#feedback-${feedbackId}`);
                            
                            if (feedbackElement && html) {
                                // Replace the feedback conversation with updated HTML
                                const tempDiv = document.createElement('div');
                                tempDiv.innerHTML = html;
                                const newFeedback = tempDiv.firstElementChild;
                                
                                if (newFeedback) {
                                    feedbackElement.replaceWith(newFeedback);
                                } else {
                                    // If no partial view returned, reload to show changes
                                    window.location.reload();
                                }
                            } else {
                                // Fallback: reload page
                                window.location.reload();
                            }
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        // Fall back to regular form submission
                        form.submit();
                    })
                    .finally(() => {
                        if (submitButton) {
                            submitButton.disabled = false;
                        }
                    });
                }
            });
            
            // Map feedback to questions/blocks when form loads
            if (typeof feedbackData !== 'undefined' && feedbackData.length > 0) {
                // This will be used by participant-form.js to show inline feedback
                window.formFeedback = {};
                let totalFeedbackCount = 0;
                feedbackData.forEach(feedback => {
                    const key = feedback.questionId || `block_${feedback.blockId}`;
                    if (!window.formFeedback[key]) {
                        window.formFeedback[key] = [];
                    }
                    window.formFeedback[key].push(feedback);
                    totalFeedbackCount++;
                });
                // Debug log to verify feedback is loaded
                console.log('[Feedback System] Loaded', totalFeedbackCount, 'conversations for', Object.keys(window.formFeedback).length, 'questions/blocks');
                
                // Show details of each conversation
                feedbackData.forEach((conv, index) => {
                    const replyCount = conv.replies ? conv.replies.length : 0;
                    console.log(`  Conversation ${index + 1}: Question ${conv.questionId || 'Block ' + conv.blockId}, Status: ${conv.status === 0 ? 'Open' : 'Closed'}, Replies: ${replyCount}`);
                });
            }
        });
    </script>
    
    <script src="~/js/businessincubators/participant-form.js"></script>
}