@model LinaSys.Web.Areas.BusinessIncubators.Models.ProjectKnowledgeStructure.ProjectKnowledgeStructureViewModel
@{
    ViewData["Title"] = "Estructura de Conocimiento del Proyecto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jstree/3.3.12/themes/default/style.min.css" />
    <style>
        .jstree-custom-icon { color: #007bff; }
        .jstree-synced { color: #28a745; }
        .jstree-customized { color: #ffc107; }
        .jstree-custom { color: #6c757d; }
        .sync-indicator {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-left: 5px;
        }
        .sync-indicator.synced { background-color: #28a745; }
        .sync-indicator.customized { background-color: #ffc107; }
        .sync-indicator.custom { background-color: #6c757d; }
        .tree-container {
            border: 1px solid #dee2e6;
            border-radius: 0.25rem;
            padding: 1rem;
            background-color: #f8f9fa;
            min-height: 600px;
            overflow-y: auto;
            max-height: calc(100vh - 350px);
        }
        .details-panel {
            border: 1px solid #dee2e6;
            border-radius: 0.25rem;
            padding: 1rem;
            background-color: white;
            min-height: 300px;
        }
        .jstree-default .jstree-hovered {
            background: #e7f3ff;
            border-radius: 2px;
            box-shadow: none;
        }
        .jstree-default .jstree-clicked {
            background: #beebff;
            border-radius: 2px;
            box-shadow: none;
        }
        .loading-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(255, 255, 255, 0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .action-buttons-section {
            background-color: #f8f9fa;
            border-radius: 0.25rem;
            padding: 1rem;
            margin-top: 1rem;
        }
        .action-btn {
            text-align: left;
            transition: all 0.2s ease-in-out;
        }
        .action-btn:hover {
            transform: translateX(5px);
        }
        .action-btn i {
            width: 20px;
            text-align: center;
            margin-right: 5px;
        }
        .action-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none !important;
        }
        /* Group different types of buttons */
        .action-btn.btn-danger {
            margin-top: 0.5rem;
        }
        /* Search functionality in link questions modal */
        #questionSearchInput {
            padding-left: 2.5rem;
        }
        #questionsListContainer .form-check {
            transition: all 0.2s ease-in-out;
        }
        #questionsListContainer h6 {
            color: #6c757d;
            font-size: 0.875rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-area="BusinessIncubators" asp-controller="Home" asp-action="Index">Incubadoras</a></li>
                    <li class="breadcrumb-item">
                        <a asp-area="BusinessIncubators" asp-controller="Projects" asp-action="Index" 
                           asp-route-businessIncubatorId="@Model.BusinessIncubatorId">Proyectos</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-area="BusinessIncubators" asp-controller="Projects" asp-action="Details" 
                           asp-route-businessIncubatorId="@Model.BusinessIncubatorId" asp-route-projectId="@Model.ProjectId">@Model.ProjectName</a>
                    </li>
                    <li class="breadcrumb-item active">Estructura de Conocimiento</li>
                </ol>
            </nav>
            <h2 class="page-title">Estructura de Conocimiento</h2>
        </div>
        <div class="col-auto">
            @if (!Model.HasKnowledgeStructure)
            {
                <button type="button" class="btn btn-primary" id="btnCopyStructure">
                    <i class="ti ti-copy"></i> Copiar Estructura
                </button>
            }
            else
            {
                <div class="btn-group">
                    <button type="button" class="btn btn-outline-danger" id="btnClearStructure">
                        <i class="ti ti-trash"></i> Limpiar
                    </button>
                    @if (Model.SourceFormId.HasValue)
                    {
                        <button type="button" class="btn btn-outline-success" id="btnSyncAll">
                            <i class="ti ti-refresh"></i> Sincronizar Todo
                        </button>
                    }
                </div>
            }
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        @if (Model.SourceFormId.HasValue)
        {
            <div class="alert alert-info d-flex align-items-center mb-3" role="alert">
                <i class="ti ti-info-circle me-2"></i>
                <div>
                    Esta estructura fue copiada desde: <strong>@Model.SourceFormName</strong>
                    <br />
                    <small>Los elementos sincronizados se actualizarán automáticamente cuando cambie el formulario origen.</small>
                </div>
            </div>
        }

        <div class="row">
            <div class="col-md-5">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Estructura</h3>
                        <div class="card-actions">
                            <div class="btn-group me-3" role="group">
                                <input type="radio" class="btn-check" name="viewMode" id="viewByBlocks" value="blocks" autocomplete="off">
                                <label class="btn btn-sm btn-outline-primary" for="viewByBlocks">
                                    <i class="ti ti-layout-list"></i> Por Bloques
                                </label>
                                <input type="radio" class="btn-check" name="viewMode" id="viewByModules" value="modules" autocomplete="off" checked>
                                <label class="btn btn-sm btn-outline-primary" for="viewByModules">
                                    <i class="ti ti-sitemap"></i> Por Módulos
                                </label>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-success me-2">
                                    <span class="sync-indicator synced"></span> Sincronizado
                                </span>
                                <span class="badge bg-warning me-2">
                                    <span class="sync-indicator customized"></span> Personalizado
                                </span>
                                <span class="badge bg-secondary">
                                    <span class="sync-indicator custom"></span> Personalizado
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <input type="text" class="form-control" id="treeSearch" placeholder="Buscar...">
                        </div>
                        <div class="tree-container">
                            <div id="knowledgeStructureTree"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-7">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Detalles</h3>
                    </div>
                    <div class="card-body">
                        <div id="detailsPanel" class="details-panel">
                            <p class="text-muted text-center">Seleccione un elemento para ver sus detalles</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal for Source Selection -->
<div class="modal fade" id="sourceSelectionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Seleccionar Estructura de Conocimiento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="sourceSelectionContent">
                <!-- Content will be loaded here -->
            </div>
        </div>
    </div>
</div>

<!-- Modal for Edit Element -->
<div class="modal fade" id="editElementModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editElementTitle">Editar Elemento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editElementForm">
                    <input type="hidden" id="editElementId" />
                    <input type="hidden" id="editElementType" />
                    
                    <div class="mb-3">
                        <label for="editElementName" class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="editElementName" required>
                    </div>
                    
                    <div class="mb-3">
                        <label for="editElementOrder" class="form-label">Orden</label>
                        <input type="number" class="form-control" id="editElementOrder" min="1" required>
                    </div>
                    
                    <div class="mb-3" id="editElementContentGroup" style="display: none;">
                        <label for="editElementContent" class="form-label">Contenido</label>
                        <textarea class="form-control" id="editElementContent" rows="4"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSaveElement">
                    <i class="ti ti-device-floppy"></i> Guardar Cambios
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal for Add Block -->
<div class="modal fade" id="addBlockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Agregar Bloque</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addBlockForm">
                    <div class="mb-3">
                        <label for="newBlockName" class="form-label">Nombre del Bloque</label>
                        <input type="text" class="form-control" id="newBlockName" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSaveBlock">
                    <i class="ti ti-plus"></i> Agregar Bloque
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal for Add Question -->
<div class="modal fade" id="addQuestionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Agregar Pregunta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addQuestionForm">
                    <input type="hidden" id="questionBlockId" />
                    
                    <div class="mb-3">
                        <label for="newQuestionText" class="form-label">Texto de la Pregunta</label>
                        <textarea class="form-control" id="newQuestionText" rows="3" required></textarea>
                    </div>
                    
                    <div class="mb-3">
                        <label for="newQuestionAnswerType" class="form-label">Tipo de Respuesta</label>
                        <select class="form-control" id="newQuestionAnswerType" required>
                            <option value="0">Texto Corto</option>
                            <option value="1">Texto Largo</option>
                            <option value="2">Sí/No</option>
                            <option value="3">Opción Múltiple</option>
                            <option value="4">Fecha</option>
                            <option value="5">Número</option>
                            <option value="6">Email</option>
                            <option value="7">URL</option>
                            <option value="8">Archivo</option>
                            <option value="9">Lista</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="newQuestionIsDiagnostic">
                            <label class="form-check-label" for="newQuestionIsDiagnostic">
                                Usar para diagnóstico
                            </label>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="newQuestionPhase" class="form-label">Fase de Aplicación</label>
                        <select class="form-control" id="newQuestionPhase">
                            <option value="0">Registro</option>
                            <option value="1">Evaluación</option>
                            <option value="2">Ambas</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label for="newQuestionTopicId" class="form-label">Vincular a Tema (opcional)</label>
                        <select class="form-control" id="newQuestionTopicId">
                            <option value="">-- Sin vincular a tema --</option>
                        </select>
                        <small class="form-text text-muted">
                            Puede vincular esta pregunta a un tema de la estructura de conocimiento
                        </small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSaveQuestion">
                    <i class="ti ti-plus"></i> Agregar Pregunta
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal for Add Module -->
<div class="modal fade" id="addModuleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Agregar Módulo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addModuleForm">
                    <div class="mb-3">
                        <label for="newModuleName" class="form-label">Nombre del Módulo</label>
                        <input type="text" class="form-control" id="newModuleName" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSaveModule">
                    <i class="ti ti-plus"></i> Agregar Módulo
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jstree/3.3.12/jstree.min.js"></script>
    <script src="~/js/businessincubators/projectknowledgestructure-edit.js"></script>
    <script>
        // Global variables for use in _EditFunctions.js
        var businessIncubatorId = '@Model.BusinessIncubatorId';
        var projectId = '@Model.ProjectId';
        
        $(document).ready(function() {
            const hasStructure = @Json.Serialize(Model.HasKnowledgeStructure);

            // Initialize tree if structure exists
            if (hasStructure) {
                initializeTree('modules'); // Default to modules view
            }
            
            // Handle view mode toggle
            $('input[name="viewMode"]').on('change', function() {
                const viewMode = $(this).val();
                if (hasStructure) {
                    $('#knowledgeStructureTree').jstree('destroy');
                    initializeTree(viewMode);
                }
            });

            // Copy structure button
            $('#btnCopyStructure').on('click', function() {
                console.log('Copy structure button clicked');
                loadSourceSelectionModal();
            });

            // Clear structure button
            $('#btnClearStructure').on('click', function() {
                if (confirm('¿Está seguro de que desea limpiar toda la estructura de conocimiento del proyecto?')) {
                    clearKnowledgeStructure();
                }
            });

            // Sync all button
            $('#btnSyncAll').on('click', function() {
                if (confirm('¿Está seguro de que desea sincronizar todos los elementos no personalizados con el formulario origen?')) {
                    syncAllElements();
                }
            });

            function initializeTree(viewMode) {
                const treeUrl = viewMode === 'blocks' 
                    ? `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/BlocksTree`
                    : `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/Tree`;
                    
                $('#knowledgeStructureTree').jstree({
                    'core': {
                        'data': {
                            'url': treeUrl,
                            'dataType': 'json'
                        },
                        'check_callback': function(operation, node, parent, position, more) {
                            if (operation === "move_node") {
                                const nodeType = node.type;
                                const parentType = parent.type;
                                
                                // Define valid moves based on view mode
                                if (viewMode === 'blocks') {
                                    const validMoves = {
                                        'block': ['root', 'project'],
                                        'question': ['block']
                                    };
                                    return validMoves[nodeType] && validMoves[nodeType].includes(parentType);
                                } else {
                                    const validMoves = {
                                        'module': ['structure'],
                                        'topic': ['module'],
                                        'subject': ['topic'],
                                        'resource': ['subject']
                                    };
                                    return validMoves[nodeType] && validMoves[nodeType].includes(parentType);
                                }
                            }
                            return true;
                        },
                        'themes': {
                            'responsive': true
                        }
                    },
                    'types': {
                        'root': {
                            'icon': 'ti ti-sitemap'
                        },
                        'structure': {
                            'icon': 'ti ti-sitemap'
                        },
                        'block': {
                            'icon': 'ti ti-layout-list'
                        },
                        'module': {
                            'icon': 'ti ti-folder'
                        },
                        'topic': {
                            'icon': 'ti ti-bookmark'
                        },
                        'subject': {
                            'icon': 'ti ti-file-text'
                        },
                        'question': {
                            'icon': 'ti ti-help-circle'
                        },
                        'answer': {
                            'icon': 'ti ti-circle-check'
                        },
                        'resource': {
                            'icon': 'ti ti-link'
                        },
                        'empty': {
                            'icon': 'ti ti-info-circle'
                        }
                    },
                    'plugins': ['types', 'contextmenu', 'dnd', 'search'],
                    'contextmenu': {
                        'items': function(node) {
                            var items = {};
                            const currentViewMode = $('input[name="viewMode"]:checked').val();
                            
                            // Add items based on view mode and node type
                            if (currentViewMode === 'blocks') {
                                // Block view context menu
                                if (node.type === 'root' || node.type === 'project') {
                                    items.addBlock = {
                                        'label': 'Agregar Bloque',
                                        'icon': 'ti ti-plus',
                                        'action': function() {
                                            showAddBlockDialog();
                                        }
                                    };
                                } else if (node.type === 'block') {
                                    items.addQuestion = {
                                        'label': 'Agregar Pregunta',
                                        'icon': 'ti ti-plus',
                                        'action': function() {
                                            showAddQuestionDialog(node);
                                        }
                                    };
                                    items.editBlock = {
                                        'label': 'Editar Bloque',
                                        'icon': 'ti ti-edit',
                                        'action': function() {
                                            showEditBlockDialog(node);
                                        }
                                    };
                                    items.deleteBlock = {
                                        'label': 'Eliminar Bloque',
                                        'icon': 'ti ti-trash',
                                        'action': function() {
                                            if (confirm('¿Está seguro de eliminar este bloque y todas sus preguntas?')) {
                                                deleteBlock(node);
                                            }
                                        }
                                    };
                                } else if (node.type === 'question') {
                                    items.addAnswer = {
                                        'label': 'Agregar Opción de Respuesta',
                                        'icon': 'ti ti-plus',
                                        'action': function() {
                                            showAddAnswerDialog(node);
                                        }
                                    };
                                    items.editQuestion = {
                                        'label': 'Editar Pregunta',
                                        'icon': 'ti ti-edit',
                                        'action': function() {
                                            showEditDialog(node);
                                        }
                                    };
                                    items.deleteQuestion = {
                                        'label': 'Eliminar Pregunta',
                                        'icon': 'ti ti-trash',
                                        'action': function() {
                                            if (confirm('¿Está seguro de eliminar esta pregunta y todas sus opciones de respuesta?')) {
                                                deleteQuestion(node);
                                            }
                                        }
                                    };
                                } else if (node.type === 'answer') {
                                    items.editAnswer = {
                                        'label': 'Editar Opción',
                                        'icon': 'ti ti-edit',
                                        'action': function() {
                                            showEditDialog(node);
                                        }
                                    };
                                    items.deleteAnswer = {
                                        'label': 'Eliminar Opción',
                                        'icon': 'ti ti-trash',
                                        'action': function() {
                                            if (confirm('¿Está seguro de eliminar esta opción de respuesta?')) {
                                                deleteAnswer(node);
                                            }
                                        }
                                    };
                                }
                            } else {
                                // Module view context menu
                                if (node.type === 'structure') {
                                    items.addModule = {
                                        'label': 'Agregar Módulo',
                                        'icon': 'ti ti-plus',
                                        'action': function() {
                                            showAddModuleDialog();
                                        }
                                    };
                                } else if (node.type === 'module') {
                                    items.addTopic = {
                                        'label': 'Agregar Tema',
                                        'icon': 'ti ti-plus',
                                        'action': function() {
                                            showAddTopicDialog(node);
                                        }
                                    };
                                    items.edit = {
                                        'label': 'Editar',
                                        'icon': 'ti ti-edit',
                                        'action': function() {
                                            showEditDialog(node);
                                        }
                                    };
                                } else if (node.type === 'topic') {
                                    items.addQuestion = {
                                        'label': 'Crear Nueva Pregunta',
                                        'icon': 'ti ti-plus',
                                        'action': function() {
                                            showAddQuestionToTopicDialog(node);
                                        }
                                    };
                                    items.linkQuestion = {
                                        'label': 'Vincular Pregunta Existente',
                                        'icon': 'ti ti-link',
                                        'action': function() {
                                            showLinkQuestionToTopicDialog(node);
                                        }
                                    };
                                    items.addSubject = {
                                        'label': 'Agregar Materia',
                                        'icon': 'ti ti-plus',
                                        'action': function() {
                                            showAddSubjectDialog(node);
                                        }
                                    };
                                    items.edit = {
                                        'label': 'Editar',
                                        'icon': 'ti ti-edit',
                                        'action': function() {
                                            showEditDialog(node);
                                        }
                                    };
                                } else if (node.type === 'subject') {
                                    items.edit = {
                                        'label': 'Editar',
                                        'icon': 'ti ti-edit',
                                        'action': function() {
                                            showEditDialog(node);
                                        }
                                    };
                                } else if (node.type === 'question') {
                                    // Questions in knowledge structure view
                                    items.addAnswer = {
                                        'label': 'Agregar Opción de Respuesta',
                                        'icon': 'ti ti-plus',
                                        'action': function() {
                                            showAddAnswerDialog(node);
                                        }
                                    };
                                    items.editQuestion = {
                                        'label': 'Editar Pregunta',
                                        'icon': 'ti ti-edit',
                                        'action': function() {
                                            showEditDialog(node);
                                        }
                                    };
                                    items.deleteQuestion = {
                                        'label': 'Eliminar Pregunta',
                                        'icon': 'ti ti-trash',
                                        'action': function() {
                                            if (confirm('¿Está seguro de eliminar esta pregunta y todas sus opciones de respuesta?')) {
                                                deleteQuestion(node);
                                            }
                                        }
                                    };
                                } else if (node.type === 'answer') {
                                    // Answer options in knowledge structure view
                                    items.editAnswer = {
                                        'label': 'Editar Opción',
                                        'icon': 'ti ti-edit',
                                        'action': function() {
                                            showEditDialog(node);
                                        }
                                    };
                                    items.deleteAnswer = {
                                        'label': 'Eliminar Opción',
                                        'icon': 'ti ti-trash',
                                        'action': function() {
                                            if (confirm('¿Está seguro de eliminar esta opción de respuesta?')) {
                                                deleteAnswer(node);
                                            }
                                        }
                                    };
                                }
                                
                                // Add sync option for customized elements
                                if ((node.type === 'module' || node.type === 'topic' || node.type === 'subject') && node.data && node.data.sourceId) {
                                    items.sync = {
                                        'label': 'Sincronizar con origen',
                                        'icon': 'ti ti-refresh',
                                        'action': function() {
                                            syncElement(node);
                                        }
                                    };
                                }
                            }
                            
                            return items;
                        }
                    }
