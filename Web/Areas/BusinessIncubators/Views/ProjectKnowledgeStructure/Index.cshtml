            // Get available actions based on node type and view mode
            function getAvailableActions(node, viewMode) {
                const actions = [];
                
                if (viewMode === 'blocks') {
                    switch(node.type) {
                        case 'root':
                        case 'project':
                            actions.push({ id: 'addBlock', label: 'Agregar Bloque', icon: 'ti ti-plus', class: 'btn-primary' });
                            break;
                        case 'block':
                            actions.push({ id: 'addQuestion', label: 'Agregar Pregunta', icon: 'ti ti-plus', class: 'btn-primary' });
                            actions.push({ id: 'editBlock', label: 'Editar Bloque', icon: 'ti ti-edit', class: 'btn-info' });
                            actions.push({ id: 'deleteBlock', label: 'Eliminar Bloque', icon: 'ti ti-trash', class: 'btn-danger', confirm: true });
                            break;
                        case 'question':
                            actions.push({ id: 'addAnswer', label: 'Agregar Opción de Respuesta', icon: 'ti ti-plus', class: 'btn-primary' });
                            actions.push({ id: 'editQuestion', label: 'Editar Pregunta', icon: 'ti ti-edit', class: 'btn-info' });
                            actions.push({ id: 'deleteQuestion', label: 'Eliminar Pregunta', icon: 'ti ti-trash', class: 'btn-danger', confirm: true });
                            break;
                        case 'answer':
                            actions.push({ id: 'editAnswer', label: 'Editar Opción', icon: 'ti ti-edit', class: 'btn-info' });
                            actions.push({ id: 'deleteAnswer', label: 'Eliminar Opción', icon: 'ti ti-trash', class: 'btn-danger', confirm: true });
                            break;
                    }
                } else {
                    // Knowledge structure view actions
                    switch(node.type) {
                        case 'structure':
                            actions.push({ id: 'addModule', label: 'Agregar Módulo', icon: 'ti ti-plus', class: 'btn-primary' });
                            break;
                        case 'module':
                            actions.push({ id: 'addTopic', label: 'Agregar Tema', icon: 'ti ti-plus', class: 'btn-primary' });
                            actions.push({ id: 'edit', label: 'Editar', icon: 'ti ti-edit', class: 'btn-info' });
                            if (node.data && node.data.sourceId) {
                                actions.push({ id: 'sync', label: 'Sincronizar con origen', icon: 'ti ti-refresh', class: 'btn-warning' });
                            }
                            break;
                        case 'topic':
                            actions.push({ id: 'addQuestionToTopic', label: 'Crear Nueva Pregunta', icon: 'ti ti-plus', class: 'btn-primary' });
                            actions.push({ id: 'linkQuestion', label: 'Vincular Pregunta Existente', icon: 'ti ti-link', class: 'btn-primary' });
                            actions.push({ id: 'addSubject', label: 'Agregar Materia', icon: 'ti ti-plus', class: 'btn-primary' });
                            actions.push({ id: 'edit', label: 'Editar', icon: 'ti ti-edit', class: 'btn-info' });
                            if (node.data && node.data.sourceId) {
                                actions.push({ id: 'sync', label: 'Sincronizar con origen', icon: 'ti ti-refresh', class: 'btn-warning' });
                            }
                            break;
                        case 'subject':
                            actions.push({ id: 'edit', label: 'Editar', icon: 'ti ti-edit', class: 'btn-info' });
                            if (node.data && node.data.sourceId) {
                                actions.push({ id: 'sync', label: 'Sincronizar con origen', icon: 'ti ti-refresh', class: 'btn-warning' });
                            }
                            break;
                        case 'question':
                            actions.push({ id: 'addAnswer', label: 'Agregar Opción de Respuesta', icon: 'ti ti-plus', class: 'btn-primary' });
                            actions.push({ id: 'editQuestion', label: 'Editar Pregunta', icon: 'ti ti-edit', class: 'btn-info' });
                            actions.push({ id: 'deleteQuestion', label: 'Eliminar Pregunta', icon: 'ti ti-trash', class: 'btn-danger', confirm: true });
                            break;
                        case 'answer':
                            actions.push({ id: 'editAnswer', label: 'Editar Opción', icon: 'ti ti-edit', class: 'btn-info' });
                            actions.push({ id: 'deleteAnswer', label: 'Eliminar Opción', icon: 'ti ti-trash', class: 'btn-danger', confirm: true });
                            break;
                    }
                }
                
                return actions;
            }
            
            // Render action buttons HTML
            function renderActionButtons(actions, node) {
                if (actions.length === 0) return '';
                
                let html = '<div class="action-buttons-section mt-4 border-top pt-3">';
                html += '<h6 class="text-muted mb-3">Acciones</h6>';
                html += '<div class="d-grid gap-2">';
                
                // Group actions by type for better organization
                const primaryActions = actions.filter(a => a.class === 'btn-primary');
                const editActions = actions.filter(a => a.class === 'btn-info');
                const dangerActions = actions.filter(a => a.class === 'btn-danger');
                const otherActions = actions.filter(a => a.class === 'btn-warning');
                
                // Render primary actions first
                primaryActions.forEach(action => {
                    html += renderSingleButton(action, node);
                });
                
                // Then edit actions
                editActions.forEach(action => {
                    html += renderSingleButton(action, node);
                });
                
                // Then other actions (sync)
                otherActions.forEach(action => {
                    html += renderSingleButton(action, node);
                });
                
                // Finally danger actions
                dangerActions.forEach(action => {
                    html += renderSingleButton(action, node);
                });
                
                html += '</div></div>';
                return html;
            }
            
            // Render a single button
            function renderSingleButton(action, node) {
                return `
                    <button type="button" 
                            class="btn ${action.class} action-btn btn-sm" 
                            data-action="${action.id}" 
                            data-node-id="${node.id}"
                            ${action.confirm ? 'data-confirm="true"' : ''}>
                        <i class="${action.icon}"></i> ${action.label}
                    </button>
                `;
            }
            
            // Bind action button events
            function bindActionButtonEvents(node) {
                $('.action-btn').off('click').on('click', function() {
                    const action = $(this).data('action');
                    const $button = $(this);
                    const needsConfirm = $(this).data('confirm');
                    
                    // Disable button during operation
                    $button.prop('disabled', true);
                    
                    // Handle confirmation for dangerous actions
                    if (needsConfirm) {
                        let confirmMessage = '';
                        switch(action) {
                            case 'deleteBlock':
                                confirmMessage = '¿Está seguro de eliminar este bloque y todas sus preguntas?';
                                break;
                            case 'deleteQuestion':
                                confirmMessage = '¿Está seguro de eliminar esta pregunta y todas sus opciones de respuesta?';
                                break;
                            case 'deleteAnswer':
                                confirmMessage = '¿Está seguro de eliminar esta opción de respuesta?';
                                break;
                        }
                        
                        if (!confirm(confirmMessage)) {
                            $button.prop('disabled', false);
                            return;
                        }
                    }
                    
                    // Execute action
                    switch(action) {
                        case 'addBlock':
                            showAddBlockDialog();
                            break;
                        case 'addQuestion':
                            showAddQuestionDialog(node);
                            break;
                        case 'addQuestionToTopic':
                            showAddQuestionToTopicDialog(node);
                            break;
                        case 'linkQuestion':
                            showLinkQuestionToTopicDialog(node);
                            break;
                        case 'addAnswer':
                            showAddAnswerDialog(node);
                            break;
                        case 'addModule':
                            showAddModuleDialog();
                            break;
                        case 'addTopic':
                            showAddTopicDialog(node);
                            break;
                        case 'addSubject':
                            showAddSubjectDialog(node);
                            break;
                        case 'edit':
                        case 'editQuestion':
                        case 'editAnswer':
                            showEditDialog(node);
                            break;
                        case 'editBlock':
                            showEditBlockDialog(node);
                            break;
                        case 'deleteBlock':
                            deleteBlock(node);
                            break;
                        case 'deleteQuestion':
                            deleteQuestion(node);
                            break;
                        case 'deleteAnswer':
                            deleteAnswer(node);
                            break;
                        case 'sync':
                            syncElement(node);
                            break;
                    }
                    
                    // Re-enable button after a short delay
                    setTimeout(() => $button.prop('disabled', false), 500);
                });
            }

            // Removed duplicate showEditDialog - using the one from _EditFunctions.js

            function syncElement(node) {
                const entityId = getNodeEntityId(node);
                if (!entityId) {
                    showToast('No se puede sincronizar este elemento', 'danger');
                    return;
                }
                
                let syncUrl = '';
                switch(node.type) {
                    case 'module':
                        syncUrl = `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/modules/${entityId}/sync`;
                        break;
                    case 'topic':
                        syncUrl = `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/topics/${entityId}/sync`;
                        break;
                    case 'subject':
                        syncUrl = `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/subjects/${entityId}/sync`;
                        break;
                    default:
                        showToast('Tipo de elemento no válido para sincronización', 'danger');
                        return;
                }
                
                if (confirm(`¿Está seguro de que desea sincronizar "${node.text}" con su origen?`)) {
                    $.ajax({
                        url: syncUrl,
                        type: 'POST',
                        beforeSend: function() {
                            showToast('Sincronizando...', 'info');
                        },
                        success: function(result) {
                            if (result.success) {
                                showToast(result.message, 'success');
                                // Reload the tree to show updated data
                                $('#knowledgeStructureTree').jstree('refresh');
                            } else {
                                showToast(result.message || 'Error al sincronizar', 'danger');
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('Error syncing element:', error);
                            showToast('Error al sincronizar el elemento', 'danger');
                        }
                    });
                }
            }
            
            // Add search functionality
            let searchTimeout;
            $('#treeSearch').on('keyup', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(function() {
                    const searchValue = $('#treeSearch').val();
                    $('#knowledgeStructureTree').jstree(true).search(searchValue);
                }, 250);
            });
            
            // Handle node move (drag and drop)
            function handleNodeMove(data) {
                const nodeType = data.node.type;
                const nodeId = data.node.data ? data.node.data.entityId : null;
                const oldParentId = data.old_parent === '#' ? null : $('#knowledgeStructureTree').jstree(true).get_node(data.old_parent).data.entityId;
                const newParentId = data.parent === '#' ? null : $('#knowledgeStructureTree').jstree(true).get_node(data.parent).data.entityId;
                const oldPosition = data.old_position;
                const newPosition = data.position;
                
                if (!nodeId) {
                    console.error('Cannot move node without ID');
                    $('#knowledgeStructureTree').jstree('refresh');
                    return;
                }
                
                // Send move request to server
                $.ajax({
                    url: `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/MoveNode`,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        nodeType: nodeType,
                        nodeId: nodeId,
                        oldParentId: oldParentId,
                        newParentId: newParentId,
                        oldPosition: oldPosition,
                        newPosition: newPosition
                    }),
                    success: function(result) {
                        if (result.success) {
                            showToast('Elemento movido exitosamente', 'success');
                        } else {
                            showToast(result.message || 'Error al mover el elemento', 'danger');
                            $('#knowledgeStructureTree').jstree('refresh');
                        }
                    },
                    error: function() {
                        showToast('Error al mover el elemento', 'danger');
                        $('#knowledgeStructureTree').jstree('refresh');
                    }
                });
            }
            
            // Dialog functions for blocks view
            function showAddBlockDialog() {
                $('#newBlockName').val('');
                $('#addBlockModal').modal('show');
            }
            
            function showAddQuestionDialog(blockNode) {
                const blockId = blockNode.data.entityId;
                $('#questionBlockId').val(blockId);
                $('#newQuestionText').val('');
                $('#newQuestionAnswerType').val('0');
                $('#newQuestionIsDiagnostic').prop('checked', false);
                $('#newQuestionPhase').val('0');
                $('#newQuestionTopicId').val('');
                
                // Load available topics
                loadAvailableTopics();
                
