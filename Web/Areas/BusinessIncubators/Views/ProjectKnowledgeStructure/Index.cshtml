                    url: `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/subjects`,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        topicId: parseInt(topicId),
                        name: name,
                        content: content || '',
                        order: parseInt(order)
                    }),
                    success: function(result) {
                        if (result.success) {
                            $('#addSubjectModal').modal('hide');
                            showToast(result.message, 'success');
                            $('#knowledgeStructureTree').jstree('refresh');
                        } else {
                            showToast(result.message || 'Error al crear la materia', 'danger');
                        }
                    },
                    error: function() {
                        showToast('Error al crear la materia', 'danger');
                    }
                });
            }
            
            // Handle save element button
            $('#btnSaveElement').on('click', function() {
                const elementId = $('#editElementId').val();
                const elementType = $('#editElementType').val();
                const name = $('#editElementName').val();
                const order = $('#editElementOrder').val();
                const content = $('#editElementContent').val();
                
                if (!name || !order) {
                    showToast('Por favor complete todos los campos requeridos', 'danger');
                    return;
                }
                
                let updateUrl = '';
                let data = {};
                
                switch(elementType) {
                    case 'module':
                        updateUrl = `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/modules/${elementId}`;
                        data = { name: name, order: parseInt(order) };
                        break;
                    case 'block':
                        updateUrl = `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/blocks/${elementId}`;
                        data = { name: name, order: parseInt(order) };
                        break;
                    case 'topic':
                        updateUrl = `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/topics/${elementId}`;
                        data = { name: name, order: parseInt(order) };
                        break;
                    case 'subject':
                        updateUrl = `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/subjects/${elementId}`;
                        data = { name: name, content: content, order: parseInt(order) };
                        break;
                    default:
                        showToast('Tipo de elemento no válido', 'danger');
                        return;
                }
                
                $.ajax({
                    url: updateUrl,
                    type: 'PUT',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    beforeSend: function() {
                        $('#btnSaveElement').prop('disabled', true);
                    },
                    success: function(result) {
                        if (result.success) {
                            $('#editElementModal').modal('hide');
                            showToast(result.message, 'success');
                            // Reload the tree to show updated data
                            $('#knowledgeStructureTree').jstree('refresh');
                        } else {
                            showToast(result.message || 'Error al actualizar', 'danger');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error updating element:', error);
                        showToast('Error al actualizar el elemento', 'danger');
                    },
                    complete: function() {
                        $('#btnSaveElement').prop('disabled', false);
                    }
                });
            });
            
            // Handle save block button
            $('#btnSaveBlock').on('click', function() {
                const blockName = $('#newBlockName').val();
                
                if (!blockName) {
                    showToast('Por favor ingrese el nombre del bloque', 'danger');
                    return;
                }
                
                $.ajax({
                    url: `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/blocks`,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ name: blockName }),
                    beforeSend: function() {
                        $('#btnSaveBlock').prop('disabled', true);
                    },
                    success: function(result) {
                        if (result.success) {
                            $('#addBlockModal').modal('hide');
                            showToast(result.message, 'success');
                            $('#knowledgeStructureTree').jstree('refresh');
                        } else {
                            showToast(result.message || 'Error al crear el bloque', 'danger');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error creating block:', error);
                        showToast('Error al crear el bloque', 'danger');
                    },
                    complete: function() {
                        $('#btnSaveBlock').prop('disabled', false);
                    }
                });
            });
            
            // Handle save question button
            $('#btnSaveQuestion').on('click', function() {
                const blockId = $('#questionBlockId').val();
                const questionText = $('#newQuestionText').val();
                const answerType = $('#newQuestionAnswerType').val();
                const isDiagnostic = $('#newQuestionIsDiagnostic').is(':checked');
                const phase = $('#newQuestionPhase').val();
                const topicId = $('#newQuestionTopicId').val();
                
                if (!questionText) {
                    showToast('Por favor ingrese el texto de la pregunta', 'danger');
                    return;
                }
                
                const requestData = {
                    blockId: parseInt(blockId),
                    text: questionText,
                    answerType: parseInt(answerType),
                    isUsedForDiagnosis: isDiagnostic,
                    appliesToPhase: parseInt(phase)
                };
                
                // Add topicId only if selected
                if (topicId) {
                    requestData.topicId = parseInt(topicId);
                }
                
                $.ajax({
                    url: `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/questions`,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(requestData),
                    beforeSend: function() {
                        $('#btnSaveQuestion').prop('disabled', true);
                    },
                    success: function(result) {
                        if (result.success) {
                            $('#addQuestionModal').modal('hide');
                            showToast(result.message, 'success');
                            $('#knowledgeStructureTree').jstree('refresh');
                        } else {
                            showToast(result.message || 'Error al crear la pregunta', 'danger');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error creating question:', error);
                        showToast('Error al crear la pregunta', 'danger');
                    },
                    complete: function() {
                        $('#btnSaveQuestion').prop('disabled', false);
                    }
                });
            });
            
            // Handle save module button
            $('#btnSaveModule').on('click', function() {
                const moduleName = $('#newModuleName').val();
                
                if (!moduleName) {
                    showToast('Por favor ingrese el nombre del módulo', 'danger');
                    return;
                }
                
                $.ajax({
                    url: `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/modules`,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ name: moduleName }),
                    beforeSend: function() {
                        $('#btnSaveModule').prop('disabled', true);
                    },
                    success: function(result) {
                        if (result.success) {
                            $('#addModuleModal').modal('hide');
                            showToast(result.message, 'success');
                            $('#knowledgeStructureTree').jstree('refresh');
                        } else {
                            showToast(result.message || 'Error al crear el módulo', 'danger');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error creating module:', error);
                        showToast('Error al crear el módulo', 'danger');
                    },
                    complete: function() {
                        $('#btnSaveModule').prop('disabled', false);
                    }
                });
            });
        });
    </script>
}