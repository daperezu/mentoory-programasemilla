            // Function for linking existing questions to topics
            function showLinkQuestionToTopicDialog(topicNode) {
                const topicId = getNodeEntityId(topicNode);
                if (!topicId) {
                    showToast('No se puede vincular preguntas a este tema', 'danger');
                    return;
                }
                
                // Get all questions that are not already linked to this topic
                $.ajax({
                    url: `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/BlocksTree`,
                    type: 'GET',
                    success: function(blocksData) {
                        const modalHtml = `
                            <div class="modal fade" id="linkQuestionToTopicModal" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Vincular Pregunta Existente a ${topicNode.text}</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="mb-3">
                                                <label for="questionSearchInput" class="form-label">Buscar pregunta:</label>
                                                <div class="input-group mb-3">
                                                    <span class="input-group-text"><i class="ti ti-search"></i></span>
                                                    <input type="text" 
                                                           class="form-control" 
                                                           id="questionSearchInput" 
                                                           placeholder="Escriba para filtrar preguntas por texto..."
                                                           autocomplete="off">
                                                    <button class="btn btn-outline-secondary" type="button" id="clearSearchBtn">
                                                        <i class="ti ti-x"></i> Limpiar
                                                    </button>
                                                </div>
                                                <small class="text-muted d-block mb-2">
                                                    <span id="searchResultCount">0</span> pregunta(s) encontrada(s)
                                                </small>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label">Seleccione una pregunta para vincular:</label>
                                                <div id="questionsListContainer" style="max-height: 400px; overflow-y: auto;">
                                                    <p class="text-muted">Cargando preguntas disponibles...</p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                        
                        // Remove existing modal if any
                        $('#linkQuestionToTopicModal').remove();
                        $('body').append(modalHtml);
                        
                        // Extract all questions from blocks tree
                        const questionsHtml = [];
                        if (blocksData && blocksData.length > 0) {
                            const projectNode = blocksData[0];
                            if (projectNode.children) {
                                projectNode.children.forEach(block => {
                                    if (block.type === 'block' && block.children) {
                                        questionsHtml.push(`<h6 class="mt-3">${block.text}</h6>`);
                                        block.children.forEach(question => {
                                            if (question.type === 'question' && question.data) {
                                                const isLinked = question.data.topicId == topicId;
                                                const topicInfo = question.data.topicInfo || '';
                                                questionsHtml.push(`
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input question-checkbox" 
                                                               type="checkbox" 
                                                               value="${question.data.entityId}" 
                                                               id="question_${question.data.entityId}"
                                                               ${isLinked ? 'checked disabled' : ''}>
                                                        <label class="form-check-label" for="question_${question.data.entityId}">
                                                            ${question.text}
                                                            ${topicInfo && !isLinked ? `<small class="text-muted">(Vinculado a: ${topicInfo})</small>` : ''}
                                                            ${isLinked ? '<small class="text-success">(Ya vinculado a este tema)</small>' : ''}
                                                        </label>
                                                    </div>
                                                `);
                                            }
                                        });
                                    }
                                });
                            }
                        }
                        
                        $('#questionsListContainer').html(questionsHtml.join('') || '<p class="text-muted">No hay preguntas disponibles</p>');
                        
                        // Store all question elements for search functionality
                        const allQuestionElements = $('#questionsListContainer .form-check').toArray();
                        const allBlockHeaders = $('#questionsListContainer h6').toArray();
                        
                        // Update search result count
                        function updateSearchCount() {
                            const visibleQuestions = $('#questionsListContainer .form-check:visible').length;
                            $('#searchResultCount').text(visibleQuestions);
                        }
                        
                        // Initial count
                        updateSearchCount();
                        
                        // Search functionality
                        $('#questionSearchInput').on('input', function() {
                            const searchTerm = $(this).val().toLowerCase().trim();
                            
                            if (searchTerm === '') {
                                // Show all questions and headers
                                $(allQuestionElements).show();
                                $(allBlockHeaders).show();
                                updateSearchCount();
                                return;
                            }
                            
                            // Hide all headers initially
                            $(allBlockHeaders).hide();
                            
                            // Filter questions
                            let currentBlockHeader = null;
                            let blockHasVisibleQuestions = false;
                            
                            $(allQuestionElements).each(function() {
                                const questionText = $(this).find('.form-check-label').text().toLowerCase();
                                const prevElement = $(this).prev();
                                
                                // Check if previous element is a block header
                                if (prevElement.is('h6')) {
                                    // Show previous block header if it had visible questions
                                    if (currentBlockHeader && blockHasVisibleQuestions) {
                                        $(currentBlockHeader).show();
                                    }
                                    currentBlockHeader = prevElement[0];
                                    blockHasVisibleQuestions = false;
                                }
                                
                                if (questionText.includes(searchTerm)) {
                                    $(this).show();
                                    blockHasVisibleQuestions = true;
                                } else {
                                    $(this).hide();
                                }
                            });
                            
                            // Show last block header if it had visible questions
                            if (currentBlockHeader && blockHasVisibleQuestions) {
                                $(currentBlockHeader).show();
                            }
                            
                            updateSearchCount();
                        });
                        
                        // Clear search button
                        $('#clearSearchBtn').on('click', function() {
                            $('#questionSearchInput').val('').trigger('input');
                        });
                        
                        // Add link button dynamically when questions are selected
                        $(document).off('change', '.question-checkbox').on('change', '.question-checkbox', function() {
                            const selectedQuestions = $('.question-checkbox:checked:not(:disabled)').length;
                            if (selectedQuestions > 0) {
                                if ($('#btnLinkQuestions').length === 0) {
                                    $('.modal-footer').prepend(`
                                        <button type="button" class="btn btn-primary" id="btnLinkQuestions">
                                            <i class="ti ti-link"></i> Vincular Preguntas Seleccionadas
                                        </button>
                                    `);
                                }
                            } else {
                                $('#btnLinkQuestions').remove();
                            }
                        });
                        
                        // Handle link button click
                        $(document).off('click', '#btnLinkQuestions').on('click', '#btnLinkQuestions', function() {
                            const selectedQuestionIds = [];
                            $('.question-checkbox:checked:not(:disabled)').each(function() {
                                selectedQuestionIds.push($(this).val());
                            });
                            
                            if (selectedQuestionIds.length === 0) {
                                showToast('Por favor seleccione al menos una pregunta', 'warning');
                                return;
                            }
                            
                            // Link each selected question to the topic
                            let completed = 0;
                            let errors = 0;
                            
                            selectedQuestionIds.forEach(questionId => {
                                // First get the question details
                                $.ajax({
                                    url: `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/questions/${questionId}`,
                                    type: 'GET',
                                    success: function(response) {
                                        if (!response.success || !response.question) {
                                            errors++;
                                            return;
                                        }
                                        
                                        const questionData = response.question;
                                        // Parse enum values from strings
                                        const answerTypeValue = parseInt(questionData.answerType) || 0;
                                        const appliesToPhaseValue = parseInt(questionData.appliesToPhase) || 0;
                                        
                                        // Now update the question with the new topicId
                                        $.ajax({
                                            url: `/BusinessIncubators/${businessIncubatorId}/Projects/${projectId}/KnowledgeStructure/questions/${questionId}`,
                                            type: 'PUT',
                                            contentType: 'application/json',
                                            data: JSON.stringify({
                                                text: questionData.text,
                                                answerType: answerTypeValue,
                                                isUsedForDiagnosis: questionData.isUsedForDiagnosis || false,
                                                appliesToPhase: appliesToPhaseValue,
                                                order: questionData.order || 999,
                                                topicId: topicId
                                            }),
                                            success: function() {
                                                completed++;
                                                if (completed + errors === selectedQuestionIds.length) {
                                                    $('#linkQuestionToTopicModal').modal('hide');
                                                    if (errors > 0) {
                                                        showToast(`${completed} pregunta(s) vinculada(s), ${errors} error(es)`, 'warning');
                                                    } else {
                                                        showToast(`${completed} pregunta(s) vinculada(s) exitosamente`, 'success');
                                                    }
                                                    $('#knowledgeStructureTree').jstree('refresh');
                                                }
                                            },
                                            error: function(xhr) {
                                                errors++;
                                                console.error('Error updating question:', xhr.responseText);
                                                if (xhr.status === 400 && xhr.responseJSON) {
                                                    const response = xhr.responseJSON;
                                                    if (response.errors) {
                                                        // Show validation errors
                                                        const errorMessages = [];
                                                        for (const field in response.errors) {
                                                            errorMessages.push(...response.errors[field]);
                                                        }
                                                        console.error('Validation errors:', errorMessages.join(', '));
                                                    }
                                                }
                                                if (completed + errors === selectedQuestionIds.length) {
                                                    $('#linkQuestionToTopicModal').modal('hide');
                                                    showToast(`${completed} pregunta(s) vinculada(s), ${errors} error(es)`, 'warning');
                                                    $('#knowledgeStructureTree').jstree('refresh');
                                                }
                                            }
                                        });
                                    },
                                    error: function() {
                                        errors++;
                                        if (completed + errors === selectedQuestionIds.length) {
                                            $('#linkQuestionToTopicModal').modal('hide');
                                            showToast(`Error al obtener datos de las preguntas`, 'danger');
                                        }
                                    }
                                });
                            });
                        });
                        
                        // Show modal
                        $('#linkQuestionToTopicModal').modal('show');
                    },
                    error: function() {
                        showToast('Error al cargar las preguntas disponibles', 'danger');
                    }
                });
            }
            
