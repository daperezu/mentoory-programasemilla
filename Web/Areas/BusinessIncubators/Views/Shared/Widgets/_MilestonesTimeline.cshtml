@model IEnumerable<dynamic>
@{
    var milestones = Model?.ToList() ?? new List<dynamic>();
    var showHeader = ViewData["ShowHeader"] ?? true;
    var title = ViewData["Title"] ?? "Hitos del Proyecto";
}

<div class="card h-100">
    @if ((bool)showHeader)
    {
        <div class="card-header bg-body-tertiary">
            <div class="row align-items-center">
                <div class="col">
                    <h6 class="mb-0">@title</h6>
                </div>
                <div class="col-auto">
                    <span class="badge badge-phoenix badge-phoenix-info">
                        @milestones.Count(m => m.Status == "completed") / @milestones.Count completados
                    </span>
                </div>
            </div>
        </div>
    }
    
    <div class="card-body">
        @if (milestones.Any())
        {
            <div class="timeline-vertical">
                @for (int i = 0; i < milestones.Count; i++)
                {
                    var milestone = milestones[i];
                    var isCompleted = milestone.Status == "completed";
                    var isCurrent = milestone.Status == "in_progress";
                    var isPending = milestone.Status == "pending";
                    var isLast = i == milestones.Count - 1;
                    
                    var statusColor = isCompleted ? "success" : isCurrent ? "warning" : isPending ? "secondary" : "danger";
                    var statusIcon = isCompleted ? "check" : isCurrent ? "spinner fa-spin" : isPending ? "clock" : "times";
                    
                    <div class="timeline-item position-relative">
                        <div class="row g-0">
                            <div class="col-auto timeline-item-bar position-relative">
                                <div class="icon-item icon-item-sm bg-@statusColor text-white rounded-circle">
                                    <span class="fas fa-@statusIcon fs-10"></span>
                                </div>
                                @if (!isLast)
                                {
                                    <span class="timeline-bar border-end border-@(isCompleted ? "success" : "300") border-dashed"></span>
                                }
                            </div>
                            <div class="col ps-3 pb-4">
                                <div class="timeline-item-content">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <h6 class="fs-9 mb-0 text-900">@milestone.Name</h6>
                                        @if (milestone.Progress != null)
                                        {
                                            <span class="badge badge-phoenix badge-phoenix-@statusColor">
                                                @milestone.Progress%
                                            </span>
                                        }
                                    </div>
                                    @if (milestone.Description != null)
                                    {
                                        <p class="fs-10 text-700 mb-2">@milestone.Description</p>
                                    }
                                    <div class="d-flex flex-wrap gap-2">
                                        @if (milestone.DueDate != null)
                                        {
                                            var isOverdue = milestone.DueDate < DateTime.Now && !isCompleted;
                                            <span class="badge badge-soft-@(isOverdue ? "danger" : isCompleted ? "success" : "primary") fs-11">
                                                <span class="far fa-calendar-alt me-1"></span>
                                                @milestone.DueDate.ToString("dd MMM yyyy")
                                            </span>
                                        }
                                        @if (milestone.AssignedTo != null)
                                        {
                                            <span class="badge badge-soft-info fs-11">
                                                <span class="far fa-user me-1"></span>
                                                @milestone.AssignedTo
                                            </span>
                                        }
                                        @if (milestone.TaskCount != null)
                                        {
                                            <span class="badge badge-soft-secondary fs-11">
                                                <span class="fas fa-tasks me-1"></span>
                                                @milestone.CompletedTasks/@milestone.TaskCount tareas
                                            </span>
                                        }
                                    </div>
                                    @if (milestone.Actions != null && milestone.Actions.Any())
                                    {
                                        <div class="mt-2">
                                            @foreach (var action in milestone.Actions)
                                            {
                                                <a href="@action.Url" class="btn btn-phoenix-@action.Type btn-sm me-1">
                                                    @if (action.Icon != null)
                                                    {
                                                        <span class="fas fa-@action.Icon me-1"></span>
                                                    }
                                                    @action.Text
                                                </a>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <span class="fas fa-flag-checkered fa-3x text-300 mb-3"></span>
                <p class="text-700">No hay hitos definidos para este proyecto</p>
            </div>
        }
    </div>
    
    @if (milestones.Any())
    {
        <div class="card-footer bg-body-tertiary">
            <div class="progress" style="height: 6px;">
                @{
                    var completedPercentage = milestones.Count > 0 
                        ? (milestones.Count(m => m.Status == "completed") * 100 / milestones.Count) 
                        : 0;
                }
                <div class="progress-bar bg-success" role="progressbar" 
                     style="width: @completedPercentage%" 
                     aria-valuenow="@completedPercentage" 
                     aria-valuemin="0" 
                     aria-valuemax="100">
                </div>
            </div>
            <p class="text-center text-700 fs-10 mb-0 mt-2">
                Progreso general: @completedPercentage% completado
            </p>
        </div>
    }
</div>