@model dynamic
@{
    var progress = Model?.Progress ?? 0;
    var title = Model?.Title ?? "Progreso";
    var subtitle = Model?.Subtitle ?? "";
    var trend = Model?.Trend ?? 0;
    var trendText = Model?.TrendText ?? "";
    var iconClass = Model?.IconClass ?? "fa-chart-line";
    var colorClass = Model?.ColorClass ?? "primary";
}

<div class="card h-100">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <h5 class="mb-2 text-800">@title</h5>
                <div class="d-flex align-items-baseline">
                    <h2 class="mb-0 text-1000">@progress%</h2>
                    @if (trend != 0)
                    {
                        <span class="badge badge-phoenix badge-phoenix-@(trend > 0 ? "success" : "danger") ms-2">
                            <span class="fas fa-caret-@(trend > 0 ? "up" : "down")"></span>
                            @Math.Abs(trend)% @trendText
                        </span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(subtitle))
                {
                    <p class="text-700 fs-10 mb-0 mt-1">@subtitle</p>
                }
            </div>
            <div class="ps-3">
                <div class="bg-@(colorClass)-subtle rounded-3 p-3">
                    <span class="fas @iconClass fa-2x text-@colorClass"></span>
                </div>
            </div>
        </div>
        
        @* Progress Bar *@
        <div class="progress mt-3" style="height: 4px;">
            <div class="progress-bar bg-@colorClass" role="progressbar" 
                 style="width: @progress%" 
                 aria-valuenow="@progress" 
                 aria-valuemin="0" 
                 aria-valuemax="100">
            </div>
        </div>
    </div>
</div>