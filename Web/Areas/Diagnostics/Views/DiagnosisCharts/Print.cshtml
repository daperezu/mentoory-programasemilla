@model LinaSys.Web.Areas.Diagnostics.Models.DiagnosisReviewViewModel
@{
    ViewData["Title"] = "Diagnóstico de Proyecto - Impresión";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        @@page {
            size: A4 landscape;
            margin: 2cm;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: white;
            padding: 20px;
        }
        
        .print-header {
            border-bottom: 2px solid #333;
            padding-bottom: 1rem;
            margin-bottom: 2rem;
        }
        
        .print-header h1 {
            font-size: 24px;
            margin-bottom: 1rem;
            color: #333;
        }
        
        .header-info {
            margin-bottom: 2rem;
        }
        
        .info-row {
            display: flex;
            margin-bottom: 0.5rem;
        }
        
        .info-label {
            font-weight: 600;
            width: 150px;
            color: #666;
        }
        
        .info-value {
            color: #333;
        }
        
        .diagnosis-chart {
            page-break-inside: avoid;
            height: 400px;
            width: 100%;
            margin-bottom: 2rem;
        }
        
        .chart-container {
            page-break-inside: avoid;
            margin-bottom: 2rem;
            padding: 1rem;
            border: 1px solid #ddd;
            border-radius: 4px;
        }
        
        .chart-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 1rem;
            text-align: center;
            color: #333;
        }
        
        .radar-chart * {
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        
        @@media print {
            body {
                padding: 0;
            }
            
            .chart-container {
                border: none;
                box-shadow: none;
            }
        }
    </style>
</head>
<body onload="window.DiagnosisChartsManager && new DiagnosisChartsManager()">
    <div class="print-header">
        <h1>Diagnóstico de Proyecto</h1>
        <div class="header-info">
            <div class="info-row">
                <span class="info-label">Incubadora:</span>
                <span class="info-value">@Model.IncubatorName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Proyecto:</span>
                <span class="info-value">@Model.ProjectName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Participante:</span>
                <span class="info-value">@Model.ParticipantName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Fase:</span>
                <span class="info-value">@Model.PhaseDisplay</span>
            </div>
            <div class="info-row">
                <span class="info-label">Fecha de Revisión:</span>
                <span class="info-value">@Model.ReviewDate.ToString("dd/MM/yyyy")</span>
            </div>
        </div>
    </div>

    <div class="charts-section">
        @foreach (var chart in Model.Charts)
        {
            <div class="chart-container">
                <h3 class="chart-title">@chart.BlockName</h3>
                <div id="@chart.ChartElementId" 
                     class="diagnosis-chart" 
                     data-diagnosis-chart="@chart.BlockId"
                     data-chart-data="@chart.ChartDataJson">
                </div>
            </div>
        }
    </div>

    <script src="~/vendors/echarts/echarts.min.js"></script>
    <script src="~/js/diagnostics/diagnosis-charts.js"></script>
    <script>
        // Auto-initialize charts and trigger print dialog after load
        window.addEventListener('load', function() {
            setTimeout(function() {
                window.print();
            }, 1000);
        });
    </script>
</body>
</html>