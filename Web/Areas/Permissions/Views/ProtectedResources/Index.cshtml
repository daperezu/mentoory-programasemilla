@using LinaSys.Permissions.Domain.Constants
@using LinaSys.Web.Models.Shared
@{
    var pageTitle = "Protected Resources";
    ViewData["Title"] = pageTitle;

    var dataTablesColumns = new List<DatatableColumn>
    {
        new()
        {
            Header = "Name", Data = "name",
            RenderType = ColRenderType.Link,
            LinkUrl = Url.Action("Details", "ProtectedResources", new { area = "Permissions", id = "{id}" })!
        },
        new() 
        { 
            Header = "Type", Data = "resourceTypeName",
            RenderType = ColRenderType.Badge,
            FilterType = ColFilterType.Select,
            FilterJs = "resourceType", // This tells DataTables to filter by the resourceType field instead
            FilterOptions = new Dictionary<string, string> {
                { "", "All Types" },
                { ResourceTypes.WebFeature.ToString(), ResourceTypes.GetDisplayName(ResourceTypes.WebFeature) },
                { ResourceTypes.BusinessIncubator.ToString(), ResourceTypes.GetDisplayName(ResourceTypes.BusinessIncubator) },
                { ResourceTypes.Project.ToString(), ResourceTypes.GetDisplayName(ResourceTypes.Project) },
                { ResourceTypes.DiagnosisForm.ToString(), ResourceTypes.GetDisplayName(ResourceTypes.DiagnosisForm) }
            },
            BadgeMap = new Dictionary<string, string> {
                { ResourceTypes.WebFeature.ToString(), ResourceTypes.GetDisplayName(ResourceTypes.WebFeature) },
                { ResourceTypes.BusinessIncubator.ToString(), ResourceTypes.GetDisplayName(ResourceTypes.BusinessIncubator) },
                { ResourceTypes.Project.ToString(), ResourceTypes.GetDisplayName(ResourceTypes.Project) },
                { ResourceTypes.DiagnosisForm.ToString(), ResourceTypes.GetDisplayName(ResourceTypes.DiagnosisForm) }
            },
            BadgeClassMap = new Dictionary<string, string> {
                { ResourceTypes.WebFeature.ToString(), "primary" },
                { ResourceTypes.BusinessIncubator.ToString(), "success" },
                { ResourceTypes.Project.ToString(), "info" },
                { ResourceTypes.DiagnosisForm.ToString(), "warning" }
            }
        },
        new() { Header = "External ID", Data = "externalId", Searchable = false, Orderable = false },
        new() { Header = "User Permissions", Data = "userPermissionsCount", Searchable = false },
        new() { Header = "Role Permissions", Data = "rolePermissionsCount", Searchable = false },
        new() { Header = "Created", Data = "createdAt", Searchable = false },
        new() { Header = "Created By", Data = "createdBy" }
    };

    var dataTablesHoverActions = new List<HoverAction>
    {
        new() { Url = Url.Action("Details", "ProtectedResources", new { area = "Permissions", id = "{id}" })!, IconClass = "fas fa-cog", Text = "Manage" }
    };
}

<page-header title="@pageTitle" icon-class="fas fa-shield-alt"></page-header>

<datatable ajax-url="@Url.Action("List", "ProtectedResources", new { area = "Permissions" })"
           columns="@dataTablesColumns"
           hover-actions="@dataTablesHoverActions"></datatable>