@page
@model ForgotPasswordModel
@{
    Layout = "_HeadlessLayout";
    ViewData["Title"] = "Olvidé mi contraseña";
}

<div class="row vh-100 g-0">
    <div class="col-lg-6">
        <div class="row flex-center h-100 g-0 px-4 px-sm-0">
            <div class="col col-sm-6 col-lg-7 col-xl-6"><a class="d-flex flex-center text-decoration-none mb-4" href="~/">
                    <div class="d-flex align-items-center fw-bolder fs-3 d-inline-block"><img src="~/img/logo-full-color-120.png" alt="phoenix" width="120" />
                    </div>
                </a>
                <div class="text-center">
                    <h4 class="text-body-highlight">Olvidaste tu contraseña?</h4>
                    <p class="text-body-tertiary mb-5">Ingresa tu correo electrónico y <br class="d-xxl-none" />te enviaremos un correo con un enlace</p>

                    <form method="post" asp-antiforgery="true" class="d-flex align-items-center mb-5">
                        <input asp-for="Input.Email" class="form-control flex-1" type="email" placeholder="Correo electrónico" />

                        <button class="btn btn-primary ms-2">Enviar<span class="fas fa-chevron-right ms-2"></span></button>
                    </form>
                    
                    <a class="fs-9 fw-bold" href="~/Home/Faqs">Aún tienes problemas?</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6 position-relative d-none d-lg-block">
        <div class="bg-holder" style="background-image:url(/assets/img/layout/forgot-password.png);">
        </div>
    </div>
</div>
