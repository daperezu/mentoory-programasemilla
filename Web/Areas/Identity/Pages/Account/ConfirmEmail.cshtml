@page
@model ConfirmEmailModel

@{
    Layout = "_HeadlessLayout";
    ViewData["Title"] = "Cuenta Confirmada";
}

<div class="container">
    <div class="row flex-center min-vh-100 py-5">
        <div class="col-sm-10 col-md-8 col-lg-6 col-xxl-5">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <a class="d-inline-block" href="~/">
                            <img src="~/img/logo-full-color-120.png" alt="logo" width="120" />
                        </a>
                    </div>
                    
                    <div class="text-center">
                        @if (Model.IsSuccess)
                        {
                            <div class="mb-4">
                                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                            </div>
                            <h3 class="mb-3">¡Cuenta Confirmada Exitosamente!</h3>
                            <p class="text-muted mb-4">
                                Tu correo electrónico ha sido verificado correctamente. 
                                Ahora puedes acceder al sistema con tus credenciales.
                            </p>
                            <div class="d-grid gap-2">
                                <a asp-page="./Login" class="btn btn-primary btn-lg">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Ir a Iniciar Sesión
                                </a>
                            </div>
                            <p class="text-muted mt-3 small">
                                Serás redirigido automáticamente en <span id="countdown">5</span> segundos...
                            </p>
                        }
                        else
                        {
                            <div class="mb-4">
                                <i class="bi bi-x-circle-fill text-danger" style="font-size: 4rem;"></i>
                            </div>
                            <h3 class="mb-3">Error al Confirmar Cuenta</h3>
                            <div class="alert alert-danger" role="alert">
                                @(Model.StatusMessage ?? "Ocurrió un error al confirmar tu correo electrónico.")
                            </div>
                            <p class="text-muted mb-4">
                                El enlace de confirmación puede haber expirado o ser inválido.
                                Por favor, contacta al administrador para obtener ayuda.
                            </p>
                            <div class="d-grid gap-2">
                                <a asp-page="./ResendEmailConfirmation" class="btn btn-primary">
                                    <i class="bi bi-envelope me-2"></i>Reenviar Correo de Confirmación
                                </a>
                                <a asp-page="./Login" class="btn btn-outline-secondary">
                                    Ir a Iniciar Sesión
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (Model.IsSuccess)
    {
        <script>
            // Auto-redirect to login after 5 seconds (only on success)
            let seconds = 5;
            const countdownElement = document.getElementById('countdown');
            const loginUrl = '@Url.Page("./Login")';
            
            const countdown = setInterval(() => {
                seconds--;
                countdownElement.textContent = seconds;
                
                if (seconds <= 0) {
                    clearInterval(countdown);
                    window.location.href = loginUrl;
                }
            }, 1000);
        </script>
    }
}
