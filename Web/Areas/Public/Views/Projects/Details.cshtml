@model LinaSys.BusinessIncubator.Application.Public.Queries.ProjectDetailDto
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = Model.Name;
}

@section Styles {
    <style>
        .hero-image-container {
            position: relative;
            height: 400px;
            overflow: hidden;
        }

        .hero-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .hero-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            padding: 3rem 0 2rem;
        }

        .timeline {
            position: relative;
            padding: 2rem 0;
        }

        .timeline-item {
            position: relative;
            padding-left: 3rem;
            margin-bottom: 2rem;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: 1rem;
            top: 2.5rem;
            bottom: -2rem;
            width: 2px;
            background: #e9ecef;
        }

        .timeline-item:last-child::before {
            display: none;
        }

        .timeline-icon {
            position: absolute;
            left: 0;
            top: 0.5rem;
            width: 2rem;
            height: 2rem;
            border-radius: 50%;
            background: #fff;
            border: 2px solid #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.875rem;
        }

        .timeline-item.active .timeline-icon {
            background: var(--phoenix-primary);
            border-color: var(--phoenix-primary);
            color: white;
        }

        .timeline-item.current .timeline-icon {
            background: #28a745;
            border-color: #28a745;
            color: white;
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: var(--phoenix-gradient);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.5rem;
        }

        .info-card {
            border: none;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            transition: all 0.3s ease;
        }

        .info-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        }
    </style>
}

<!-- Hero Section -->
<section class="position-relative">
    <div class="hero-image-container">
        <img src="@Model.HeroImageUrl" alt="@Model.Name" class="hero-image">
        <div class="hero-overlay">
            <div class="container">
                <h1 class="display-4 text-white mb-3">@Model.Name</h1>
                <p class="lead text-white mb-0">
                    <i class="fas fa-building me-2"></i>@Model.BusinessIncubatorName
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Metadata Chips -->
<section class="py-3 border-bottom bg-light">
    <div class="container">
        <div class="d-flex flex-wrap gap-2">
            <span class="badge bg-primary">
                <i class="fas fa-tag me-1"></i>@Model.Status
            </span>
            @if (Model.StartDate.HasValue)
            {
                <span class="badge bg-info">
                    <i class="fas fa-calendar me-1"></i>Inicia: @Model.StartDate.Value.ToString("dd MMM yyyy")
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.LocationName))
            {
                <span class="badge bg-success">
                    <i class="fas fa-map-marker-alt me-1"></i>@Model.LocationName
                </span>
            }
            @if (Model.ActiveParticipants > 0)
            {
                <span class="badge bg-warning text-dark">
                    <i class="fas fa-users me-1"></i>@Model.ActiveParticipants participantes activos
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.CurrentStageName))
            {
                <span class="badge bg-secondary">
                    <i class="fas fa-flag me-1"></i>Etapa actual: @Model.CurrentStageName
                </span>
            }
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-5">
    <div class="container">
        <div class="row">
            <!-- Left Column - Project Details -->
            <div class="col-lg-8">
                <!-- Description Card -->
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="card info-card mb-4">
                        <div class="card-body">
                            <h3 class="card-title mb-3">
                                <i class="fas fa-info-circle text-primary me-2"></i>Acerca del Proyecto
                            </h3>
                            <p class="card-text">@Model.Description</p>
                        </div>
                    </div>
                }

                <!-- Stages Timeline -->
                @if (Model.Stages.Any())
                {
                    <div class="card info-card mb-4">
                        <div class="card-body">
                            <h3 class="card-title mb-4">
                                <i class="fas fa-tasks text-primary me-2"></i>Cronograma del Proyecto
                            </h3>
                            <div class="timeline">
                                @foreach (var stage in Model.Stages)
                                {
                                    var itemClass = "timeline-item";
                                    if (stage.IsCurrent) itemClass += " current";
                                    else if (stage.IsActive) itemClass += " active";

                                    <div class="@itemClass">
                                        <div class="timeline-icon">
                                            @if (stage.IsCurrent)
                                            {
                                                <i class="fas fa-play"></i>
                                            }
                                            else if (stage.IsActive)
                                            {
                                                <i class="fas fa-check"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-clock"></i>
                                            }
                                        </div>
                                        <div class="timeline-content">
                                            <h5 class="mb-2">@stage.Title</h5>
                                            <p class="text-muted small mb-2">
                                                <i class="far fa-calendar me-1"></i>
                                                @stage.StartDate.ToString("dd MMM") - @stage.EndDate.ToString("dd MMM yyyy")
                                            </p>
                                            @if (!string.IsNullOrWhiteSpace(stage.Description))
                                            {
                                                <p class="mb-0">@stage.Description</p>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- Location Map (placeholder for future implementation) -->
                @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
                {
                    <div class="card info-card mb-4">
                        <div class="card-body">
                            <h3 class="card-title mb-3">
                                <i class="fas fa-map text-primary me-2"></i>Ubicación
                            </h3>
                            <div class="bg-light p-4 text-center text-muted">
                                <i class="fas fa-map-marked-alt fa-3x mb-3"></i>
                                <p>@Model.LocationName</p>
                                <small>Lat: @Model.Latitude, Lon: @Model.Longitude</small>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Right Column - Sidebar -->
            <div class="col-lg-4">
                <!-- Organizer Card -->
                <div class="card info-card mb-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Organizador</h5>
                        <div class="d-flex align-items-center mb-3">
                            <div class="avatar">
                                @Model.BusinessIncubatorName.Substring(0, 1).ToUpper()
                            </div>
                            <div class="ms-3">
                                <h6 class="mb-0">@Model.BusinessIncubatorName</h6>
                                <small class="text-muted">Incubadora de Negocios</small>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.BusinessIncubatorDescription))
                        {
                            <p class="small text-muted">@Model.BusinessIncubatorDescription</p>
                        }
                    </div>
                </div>

                <!-- CTA Card -->
                <div class="card bg-gradient-primary text-white">
                    <div class="card-body text-center">
                        <h5 class="card-title">¿Interesado en este proyecto?</h5>
                        <p class="card-text">Únete a esta emocionante oportunidad de emprendimiento</p>
                        <button class="btn btn-light btn-lg w-100" id="btnRegisterInterest">
                            <i class="fas fa-heart me-2"></i>Registrar Interés
                        </button>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card info-card mt-4">
                    <div class="card-body">
                        <h6 class="card-title mb-3">Acciones Rápidas</h6>
                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-primary" onclick="shareProject()">
                                <i class="fas fa-share-alt me-2"></i>Compartir
                            </button>
                            <a href="@Url.Action("Index", "Projects", new { area = "Public" })" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Ver Más Proyectos
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Register interest button
            document.getElementById('btnRegisterInterest')?.addEventListener('click', function() {
                // TODO: Implement interest registration
                Swal.fire({
                    icon: 'info',
                    title: 'Próximamente',
                    text: 'La funcionalidad de registro de interés estará disponible pronto.',
                    confirmButtonText: 'Entendido',
                    confirmButtonColor: '#667eea'
                });
            });
        });

        function shareProject() {
            if (navigator.share) {
                navigator.share({
                    title: '@Model.Name',
                    text: 'Mira este proyecto de emprendimiento: @Model.Name',
                    url: window.location.href
                }).catch(err => console.log('Error sharing:', err));
            } else {
                // Fallback - copy to clipboard
                navigator.clipboard.writeText(window.location.href).then(function() {
                    Swal.fire({
                        icon: 'success',
                        title: 'Enlace copiado',
                        text: 'El enlace del proyecto ha sido copiado al portapapeles.',
                        timer: 2000,
                        showConfirmButton: false
                    });
                });
            }
        }
    </script>
}