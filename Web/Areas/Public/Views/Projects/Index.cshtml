@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Descubre Proyectos Cercanos";
}

<div class="container-fluid px-0">
    <!-- Hero Section -->
    <section class="hero-section bg-gradient-primary text-white py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <h1 class="display-4 fw-bold mb-4">Descubre Proyectos de Emprendimiento Cerca de Ti</h1>
                    <p class="lead mb-4">Conecta con emprendedores locales, explora proyectos innovadores y forma parte del ecosistema de emprendimiento en tu área.</p>
                    <button id="btnEnableLocation" class="btn btn-light btn-lg me-3">
                        <i class="fas fa-location-arrow me-2"></i>Usar mi Ubicación
                    </button>
                    <button id="btnManualSearch" class="btn btn-outline-light btn-lg">
                        <i class="fas fa-search me-2"></i>Buscar Manualmente
                    </button>
                </div>
                <div class="col-lg-6">
                    <div id="mapContainer" class="rounded shadow" style="height: 400px;">
                        <!-- Map will be rendered here -->
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Anti-forgery token for AJAX requests -->
    @Html.AntiForgeryToken()

    <!-- Location Permission Status -->
    <div id="locationStatus" class="alert alert-info d-none m-3" role="alert">
        <i class="fas fa-info-circle me-2"></i>
        <span id="locationStatusText"></span>
    </div>

    <!-- Loading Indicator -->
    <div id="loadingIndicator" class="text-center py-5 d-none">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Buscando proyectos...</span>
        </div>
        <p class="mt-3">Buscando proyectos cercanos...</p>
    </div>

    <!-- Projects Grid -->
    <section id="projectsSection" class="py-5 d-none">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="h3">Proyectos Encontrados</h2>
                <div class="d-flex align-items-center">
                    <label class="me-2">Radio de búsqueda:</label>
                    <select id="radiusSelect" class="form-select form-select-sm" style="width: auto;">
                        <option value="5">5 km</option>
                        <option value="10">10 km</option>
                        <option value="15" selected>15 km</option>
                        <option value="25">25 km</option>
                        <option value="50">50 km</option>
                    </select>
                </div>
            </div>
            
            <div id="projectsGrid" class="row g-4">
                <!-- Project cards will be rendered here -->
            </div>

            <!-- No Projects Message -->
            <div id="noProjectsMessage" class="text-center py-5 d-none">
                <i class="fas fa-map-marked-alt fa-3x text-muted mb-3"></i>
                <h3>No se encontraron proyectos en esta área</h3>
                <p class="text-muted">Intenta ampliar el radio de búsqueda o buscar en otra ubicación.</p>
            </div>
        </div>
    </section>

    <!-- Manual Search Modal -->
    <div class="modal fade" id="manualSearchModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Buscar por Ubicación</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="searchAddress" class="form-label">Dirección o Ciudad</label>
                        <input type="text" class="form-control" id="searchAddress" placeholder="Ej: San José, Costa Rica">
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <label for="manualLat" class="form-label">Latitud</label>
                            <input type="number" class="form-control" id="manualLat" step="0.000001" placeholder="9.934739">
                        </div>
                        <div class="col-md-6">
                            <label for="manualLon" class="form-label">Longitud</label>
                            <input type="number" class="form-control" id="manualLon" step="0.000001" placeholder="-84.087502">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" id="btnSearchLocation">Buscar Proyectos</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .hero-section {
            background: linear-gradient(135deg, var(--phoenix-primary), #2c5cc5);
        }
        
        .project-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            cursor: pointer;
            height: 100%;
        }
        
        .project-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        }
        
        .distance-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(255,255,255,0.9);
            padding: 5px 10px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 0.875rem;
        }
        
        #mapContainer {
            background: linear-gradient(45deg, #f0f0f0 25%, transparent 25%),
                        linear-gradient(-45deg, #f0f0f0 25%, transparent 25%),
                        linear-gradient(45deg, transparent 75%, #f0f0f0 75%),
                        linear-gradient(-45deg, transparent 75%, #f0f0f0 75%);
            background-size: 20px 20px;
            background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
        }
        
        .bg-gradient-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
    </style>
}

@section Scripts {
    <script src="~/js/public-projects.js"></script>
}