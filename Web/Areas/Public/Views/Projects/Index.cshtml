@using LinaSys.BusinessIncubator.Application.Public.Queries
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Descubre Proyectos de Emprendimiento";
    var latestProjects = ViewData["LatestProjects"] as LatestProjectsDto ?? new LatestProjectsDto { Projects = new List<LatestProjectDto>() };
}

<!-- Hero Section with Phoenix Gradient -->
<section class="hero-gradient text-white py-5">
    <div class="container">
        <div class="row align-items-center min-vh-50">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4 animate-fade-in-up">
                    Descubre Proyectos de Emprendimiento e Innovación
                </h1>
                <p class="lead mb-4 animate-fade-in-up" style="animation-delay: 0.1s;">
                    Conecta con emprendedores locales, explora proyectos innovadores y forma parte del ecosistema de emprendimiento en Costa Rica.
                </p>
                <div class="d-flex flex-wrap gap-3 animate-fade-in-up" style="animation-delay: 0.2s;">
                    <button id="btnExploreProjects" class="btn btn-light btn-lg">
                        <i class="fas fa-compass me-2"></i>Explorar Proyectos
                    </button>
                    <button id="btnEnableLocation" class="btn btn-outline-light btn-lg">
                        <i class="fas fa-location-arrow me-2"></i>Usar mi Ubicación
                    </button>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <div class="position-relative">
                    <svg viewBox="0 0 400 300" class="w-100" style="max-width: 500px;">
                        <!-- Innovation Illustration -->
                        <defs>
                            <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:rgba(255,255,255,0.3);stop-opacity:1" />
                                <stop offset="100%" style="stop-color:rgba(255,255,255,0.1);stop-opacity:1" />
                            </linearGradient>
                        </defs>
                        <circle cx="200" cy="150" r="80" fill="url(#grad1)" />
                        <circle cx="100" cy="100" r="50" fill="url(#grad1)" />
                        <circle cx="300" cy="200" r="60" fill="url(#grad1)" />
                        <path d="M 150 150 Q 200 50 250 150" stroke="white" stroke-width="2" fill="none" opacity="0.5"/>
                        <path d="M 100 200 Q 200 100 300 200" stroke="white" stroke-width="2" fill="none" opacity="0.3"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Value Propositions -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-6 fw-bold">¿Por qué unirse a nuestro ecosistema?</h2>
            <p class="lead text-muted">Potencia tu emprendimiento con las herramientas adecuadas</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4">
                <div class="card card-phoenix h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle mb-3">
                            <i class="fas fa-rocket fa-2x"></i>
                        </div>
                        <h5 class="card-title">Aceleración</h5>
                        <p class="text-muted">Programas intensivos de desarrollo empresarial con mentores expertos</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card card-phoenix h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle mb-3">
                            <i class="fas fa-users fa-2x"></i>
                        </div>
                        <h5 class="card-title">Red de Contactos</h5>
                        <p class="text-muted">Conecta con otros emprendedores, inversores y socios estratégicos</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card card-phoenix h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle mb-3">
                            <i class="fas fa-chart-line fa-2x"></i>
                        </div>
                        <h5 class="card-title">Crecimiento</h5>
                        <p class="text-muted">Herramientas y recursos para escalar tu negocio al siguiente nivel</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card card-phoenix h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle mb-3">
                            <i class="fas fa-graduation-cap fa-2x"></i>
                        </div>
                        <h5 class="card-title">Formación</h5>
                        <p class="text-muted">Talleres, cursos y capacitaciones especializadas en emprendimiento</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card card-phoenix h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle mb-3">
                            <i class="fas fa-hand-holding-usd fa-2x"></i>
                        </div>
                        <h5 class="card-title">Financiamiento</h5>
                        <p class="text-muted">Acceso a inversionistas y opciones de financiamiento para tu proyecto</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-4">
                <div class="card card-phoenix h-100">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle mb-3">
                            <i class="fas fa-lightbulb fa-2x"></i>
                        </div>
                        <h5 class="card-title">Innovación</h5>
                        <p class="text-muted">Metodologías ágiles y design thinking para innovar constantemente</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Anti-forgery token for AJAX requests -->
@Html.AntiForgeryToken()

<!-- Location Permission Status (Hidden by default) -->
<div id="locationStatus" class="alert alert-info d-none m-3" role="alert">
    <i class="fas fa-info-circle me-2"></i>
    <span id="locationStatusText"></span>
</div>

<!-- Latest Projects Section (Default View) -->
<section id="latestProjectsSection" class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="h3 mb-1">Próximos Proyectos</h2>
                <p class="text-muted mb-0">Los proyectos más recientes en nuestro ecosistema</p>
            </div>
            <div class="sort-indicator">
                <i class="fas fa-clock"></i>
                Ordenado por: Fecha de inicio
            </div>
        </div>

        <div id="latestProjectsGrid" class="row g-4">
            @if (latestProjects.Projects.Any())
            {
                @foreach (var project in latestProjects.Projects)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card project-card card-phoenix h-100">
                            @if (!string.IsNullOrEmpty(project.HeroImageUrl))
                            {
                                <img src="@project.HeroImageUrl" class="card-img-top" alt="@project.Name">
                                @if (project.NextStageStartDate.HasValue)
                                {
                                    <span class="stage-badge">
                                        @((project.NextStageStartDate.Value - DateTime.Now).Days <= 7 ? "Inicia pronto" : project.NextStageTitle ?? "Próximamente")
                                    </span>
                                }
                            }
                            <div class="card-body">
                                <h5 class="card-title">@project.Name</h5>
                                <p class="text-muted small mb-2">
                                    <i class="fas fa-building me-1"></i>@project.BusinessIncubatorName
                                </p>
                                @if (!string.IsNullOrEmpty(project.LocationName))
                                {
                                    <p class="text-muted small mb-2">
                                        <i class="fas fa-map-marker-alt me-1"></i>@project.LocationName
                                    </p>
                                }
                                @if (project.NextStageStartDate.HasValue)
                                {
                                    <p class="text-primary small mb-2">
                                        <i class="fas fa-calendar me-1"></i>Inicia @project.NextStageStartDate.Value.ToString("dd MMM yyyy")
                                    </p>
                                }
                                <p class="card-text text-truncate-2">
                                    @(project.Description ?? "Descubre más sobre este proyecto innovador")
                                </p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="badge bg-info-subtle text-info">
                                        <i class="fas fa-users me-1"></i>@project.ActiveParticipants participantes
                                    </span>
                                    <a href="/Public/Projects/Details/@project.ExternalId" class="btn btn-sm btn-phoenix-primary">
                                        Ver detalles <i class="fas fa-arrow-right ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <i class="fas fa-rocket fa-3x text-muted mb-3"></i>
                    <h4>Nuevos proyectos próximamente</h4>
                    <p class="text-muted">Estamos preparando nuevas oportunidades de emprendimiento</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- Nearby Projects Section (Hidden until location is shared) -->
<section id="nearbyProjectsSection" class="py-5 bg-light d-none">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="h3 mb-1">Proyectos Cercanos</h2>
                <p class="text-muted mb-0">Proyectos en tu área</p>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="sort-indicator">
                    <i class="fas fa-map-marker-alt"></i>
                    Ordenado por: Cercanía
                </div>
                <select id="radiusSelect" class="form-select form-select-sm" style="width: auto;">
                    <option value="5">5 km</option>
                    <option value="10">10 km</option>
                    <option value="15" selected>15 km</option>
                    <option value="25">25 km</option>
                    <option value="50">50 km</option>
                </select>
            </div>
        </div>

        <div id="nearbyProjectsGrid" class="row g-4">
            <!-- Projects will be loaded here via AJAX -->
        </div>

        <div id="noProjectsMessage" class="text-center py-5 d-none">
            <i class="fas fa-map-marked-alt fa-3x text-muted mb-3"></i>
            <h3>No se encontraron proyectos en esta área</h3>
            <p class="text-muted">Intenta ampliar el radio de búsqueda o explora todos los proyectos disponibles.</p>
        </div>
    </div>
</section>

<!-- Loading Indicator -->
<div id="loadingIndicator" class="text-center py-5 d-none">
    <div class="spinner-phoenix mx-auto mb-3"></div>
    <p class="text-muted">Buscando proyectos cercanos...</p>
</div>

<!-- How It Works Timeline -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-6 fw-bold">¿Cómo funciona?</h2>
            <p class="lead text-muted">Tu camino hacia el éxito empresarial</p>
        </div>
        <div class="row">
            <div class="col-md-10 mx-auto">
                <div class="timeline">
                    <div class="timeline-item active">
                        <div class="timeline-icon">
                            <i class="fas fa-check"></i>
                        </div>
                        <div class="timeline-content">
                            <h5>1. Explora Proyectos</h5>
                            <p class="text-muted">Descubre oportunidades de emprendimiento que se alineen con tus intereses y habilidades</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-icon"></div>
                        <div class="timeline-content">
                            <h5>2. Regístrate</h5>
                            <p class="text-muted">Crea tu perfil y aplica a los programas que más te interesen</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-icon"></div>
                        <div class="timeline-content">
                            <h5>3. Participa</h5>
                            <p class="text-muted">Únete a sesiones de mentoría, talleres y eventos de networking</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-icon"></div>
                        <div class="timeline-content">
                            <h5>4. Crece</h5>
                            <p class="text-muted">Desarrolla tu proyecto con el apoyo de expertos y recursos especializados</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-6 fw-bold">Lo que dicen nuestros emprendedores</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="testimonial-card">
                    <p class="mb-3">"El programa me ayudó a transformar mi idea en un negocio real. El apoyo y mentoría fueron fundamentales."</p>
                    <div class="d-flex align-items-center">
                        <div class="avatar avatar-lg me-3">
                            <div class="avatar-name rounded-circle bg-primary-subtle">
                                <span class="fs-7 text-primary">MA</span>
                            </div>
                        </div>
                        <div>
                            <h6 class="mb-0">María Alvarado</h6>
                            <small class="text-muted">Fundadora, EcoTech Solutions</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="testimonial-card">
                    <p class="mb-3">"Encontré no solo financiamiento, sino una red de contactos invaluable para hacer crecer mi startup."</p>
                    <div class="d-flex align-items-center">
                        <div class="avatar avatar-lg me-3">
                            <div class="avatar-name rounded-circle bg-success-subtle">
                                <span class="fs-7 text-success">JR</span>
                            </div>
                        </div>
                        <div>
                            <h6 class="mb-0">Juan Rodríguez</h6>
                            <small class="text-muted">CEO, AgroSmart CR</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="testimonial-card">
                    <p class="mb-3">"La formación y el acompañamiento constante marcaron la diferencia en el éxito de mi proyecto."</p>
                    <div class="d-flex align-items-center">
                        <div class="avatar avatar-lg me-3">
                            <div class="avatar-name rounded-circle bg-info-subtle">
                                <span class="fs-7 text-info">LC</span>
                            </div>
                        </div>
                        <div>
                            <h6 class="mb-0">Laura Castro</h6>
                            <small class="text-muted">Directora, FinTech Innova</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 bg-primary-subtle">
    <div class="container text-center">
        <h2 class="display-6 fw-bold mb-3">¿Listo para emprender?</h2>
        <p class="lead mb-4">Únete a nuestra comunidad de innovadores y transforma tu idea en realidad</p>
        <a href="/Identity/Account/Register" class="btn btn-phoenix-primary btn-lg">
            <i class="fas fa-rocket me-2"></i>Comienza ahora
        </a>
    </div>
</section>

@section Styles {
    <style>
        .text-truncate-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .avatar-name {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }
    </style>
}

@section Scripts {
    <script src="~/js/public-projects-phoenix.js"></script>
}