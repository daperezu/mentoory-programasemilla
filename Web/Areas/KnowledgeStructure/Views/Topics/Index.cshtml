@{
    var pageTitle = "Gestión de Temas";
    ViewData["Title"] = pageTitle;

    var pageHeaderActions = new List<PageHeaderDropdownItem>()
    {
        new()
        {
            IconClass = "fa-solid fa-plus me-2",
            Text = "Nuevo tema",
            Url = Url.Action("Create", "Topics", new { area = "KnowledgeStructure" })!
        }
    };

    var dataTablesColumns = new List<DatatableColumn>
    {
        new()
        {
            Header = "Nombre", 
            Data = "name"
        },
        new()
        {
            Header = "Descripción", 
            Data = "description"
        },
        new()
        {
            Header = "Módulo", 
            Data = "moduleName"
        },
        new()
        {
            Header = "Estructura de Conocimiento", 
            Data = "knowledgeStructureName"
        },
        new()
        {
            Header = "Cantidad de Asignaturas", 
            Data = "subjectCount"
        }
    };

    var dataTablesHoverActions = new List<HoverAction>
    {
        new() { 
            Url = Url.Action("Edit", "Topics", new { area = "KnowledgeStructure", id = "{id}" })!, 
            IconClass = "fas fa-edit",
            Text = "Editar"
        },
        new() { 
            Url = Url.Action("ManageModules", "Topics", new { area = "KnowledgeStructure", id = "{topicId}" })!, 
            IconClass = "fas fa-sitemap",
            Text = "Gestionar Módulos"
        }
    };
}

<page-header title="@pageTitle" icon-class="fas fa-book" dropdown-items="@pageHeaderActions"></page-header>

<datatable ajax-url="@Url.Action("List", "Topics", new { area = "KnowledgeStructure" })"
           columns="@dataTablesColumns"
           hover-actions="@dataTablesHoverActions"></datatable>
