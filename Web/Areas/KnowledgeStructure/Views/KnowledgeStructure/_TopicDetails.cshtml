@model LinaSys.KnowledgeStructure.Application.Topic.DTOs.TopicDetailDto

<div class="card">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0">
            <i class="fa fa-file-text"></i> Tema
        </h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Nombre:</dt>
            <dd class="col-sm-8">@Model.Name</dd>
            
            <dt class="col-sm-4">Descripción:</dt>
            <dd class="col-sm-8">@(Model.Description ?? "Sin descripción")</dd>
            
            <dt class="col-sm-4">Orden:</dt>
            <dd class="col-sm-8">@Model.Order</dd>
            
            <dt class="col-sm-4">Módulo:</dt>
            <dd class="col-sm-8">@Model.ModuleName</dd>
            
            <dt class="col-sm-4">Estructura:</dt>
            <dd class="col-sm-8">@Model.KnowledgeStructureName</dd>
            
            <dt class="col-sm-4">Asignaturas:</dt>
            <dd class="col-sm-8">@Model.SubjectCount</dd>
        </dl>
        
        <div class="node-actions">
            <a href="@Url.Action("Edit", "Topics", new { id = Model.Id })" class="btn btn-primary">
                <i class="fa fa-edit"></i> Editar
            </a>
            <a href="@Url.Action("Create", "Subjects", new { structureTopicId = Model.Id })" class="btn btn-success">
                <i class="fa fa-plus"></i> Agregar Asignatura
            </a>
            <button type="button" class="btn btn-danger" onclick="deleteTopic(@Model.Id)">
                <i class="fa fa-trash"></i> Eliminar
            </button>
        </div>
    </div>
</div>