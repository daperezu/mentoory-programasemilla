@model LinaSys.Web.Areas.KnowledgeStructure.Models.KnowledgeStructure.EditKnowledgeStructureViewModel

@{
    ViewData["Title"] = "Editar Estructura de Conocimiento";
}

<page-header title="@ViewData["Title"]">
    <breadcrumb>
        <breadcrumb-item title="Inicio" asp-area="" asp-controller="Home" asp-action="Index"></breadcrumb-item>
        <breadcrumb-item title="Estructuras de Conocimiento" asp-area="KnowledgeStructure" asp-controller="KnowledgeStructure" asp-action="Index"></breadcrumb-item>
        <breadcrumb-item title="Editar" active="true"></breadcrumb-item>
    </breadcrumb>
</page-header>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i> Guardar cambios
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times me-1"></i> Cancelar
                        </a>
                        <a asp-action="Builder" class="btn btn-info ms-auto">
                            <i class="fas fa-sitemap me-1"></i> Ir al constructor
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Información</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">
                    Los cambios en la estructura de conocimiento afectarán a todos los módulos, temas y materias asociados.
                </p>
                <p class="text-muted">
                    Si desactiva la estructura, no estará disponible para nuevos proyectos, pero los existentes no se verán afectados.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}