@model LinaSys.Web.Areas.KnowledgeStructure.Models.Subject.ManageSubjectTopicsViewModel

@{
    ViewData["Title"] = "Gestionar Temas de la Materia";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Materias</a></li>
                    <li class="breadcrumb-item active">Gestionar Temas</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3">@ViewData["Title"]</h1>
            <p class="text-muted">
                Materia: <strong>@Model.SubjectName</strong>
                @if (!string.IsNullOrEmpty(Model.SubjectDescription))
                {
                    <br />
                    <small>@Model.SubjectDescription</small>
                }
            </p>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Temas que Referencian esta Materia</h5>
                </div>
                <div class="card-body">
                    @if (Model.AssignedTopics.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Tema</th>
                                        <th>Módulo</th>
                                        <th>Estructura de Conocimiento</th>
                                        <th>Orden</th>
                                        <th style="width: 100px;">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var topic in Model.AssignedTopics)
                                    {
                                        <tr>
                                            <td>@topic.TopicName</td>
                                            <td>@topic.ModuleName</td>
                                            <td>@topic.KnowledgeStructureName</td>
                                            <td>@topic.Order</td>
                                            <td>
                                                <form asp-action="RemoveFromTopic" method="post" class="d-inline" 
                                                      onsubmit="return confirm('¿Está seguro de que desea remover esta materia del tema?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="subjectId" value="@Model.SubjectId" />
                                                    <input type="hidden" name="structureTopicId" value="@topic.StructureTopicId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" 
                                                            title="Remover del tema">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            Esta materia no está referenciada por ningún tema.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Asignar a Tema</h5>
                </div>
                <div class="card-body">
                    @if (Model.AvailableTopics.Any())
                    {
                        <form asp-action="AddToTopic" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="subjectId" value="@Model.SubjectId" />
                            
                            <div class="mb-3">
                                <label for="structureTopicId" class="form-label">Seleccionar Tema</label>
                                <select name="structureTopicId" id="structureTopicId" class="form-select" required>
                                    <option value="">-- Seleccione un tema --</option>
                                    @foreach (var topic in Model.AvailableTopics)
                                    {
                                        <option value="@topic.Value">@topic.Text</option>
                                    }
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-plus-circle me-2"></i>Asignar
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            No hay temas disponibles para asignar.
                        </div>
                    }
                </div>
            </div>

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Volver a la lista
                </a>
            </div>
        </div>
    </div>
</div>