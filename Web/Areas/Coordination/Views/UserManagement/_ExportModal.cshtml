@* Export Modal *@
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportModalLabel">
                    <i class="fas fa-download"></i> Exportar Usuarios
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form id="exportForm" method="get" action="@Url.Action("ExportUsers", "UserManagement")">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Formato de Exportación</label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="format" id="formatExcel" value="xlsx" checked>
                            <label class="form-check-label" for="formatExcel">
                                <i class="fas fa-file-excel text-success"></i> Excel (.xlsx)
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="format" id="formatCsv" value="csv">
                            <label class="form-check-label" for="formatCsv">
                                <i class="fas fa-file-csv text-primary"></i> CSV (.csv)
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="searchTerm" class="form-label">Filtrar por búsqueda (opcional)</label>
                        <input type="text" class="form-control" id="searchTerm" name="searchTerm" 
                               placeholder="Nombre, apellido, email o identificación">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Estado de usuarios</label>
                        <select class="form-select" name="isActive">
                            <option value="">Todos los usuarios</option>
                            <option value="true">Solo usuarios activos</option>
                            <option value="false">Solo usuarios inactivos</option>
                        </select>
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> 
                        La exportación incluirá todos los usuarios que coincidan con los filtros seleccionados.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-download"></i> Exportar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Optional: Add JavaScript to handle export with current DataTable filters
    document.addEventListener('DOMContentLoaded', function() {
        const exportForm = document.getElementById('exportForm');
        if (exportForm) {
            exportForm.addEventListener('submit', function(e) {
                // Get current DataTable search value if available
                const table = $('#userManagementTable').DataTable();
                if (table && !document.getElementById('searchTerm').value) {
                    const searchValue = table.search();
                    if (searchValue) {
                        document.getElementById('searchTerm').value = searchValue;
                    }
                }
            });
        }
    });
</script>