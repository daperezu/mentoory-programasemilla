@model LinaSys.Web.Areas.Coordination.Models.UserManagement.CreateUserViewModel
@{
    ViewData["Title"] = "Crear Usuario";
}

@section Styles {
    <style>
        .wizard-container {
            min-height: 500px;
        }
        .step-indicator {
            display: flex;
            justify-content: space-between;
            margin-bottom: 2rem;
        }
        .step {
            flex: 1;
            text-align: center;
            position: relative;
        }
        .step:not(:last-child)::after {
            content: '';
            position: absolute;
            top: 20px;
            left: 50%;
            width: 100%;
            height: 2px;
            background: #e9ecef;
            z-index: -1;
        }
        .step.active::after,
        .step.completed::after {
            background: var(--phoenix-primary);
        }
        .step-number {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #e9ecef;
            color: #6c757d;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            margin-bottom: 0.5rem;
        }
        .step.active .step-number {
            background: var(--phoenix-primary);
            color: white;
        }
        .step.completed .step-number {
            background: #00d97e;
            color: white;
        }
        .role-card {
            cursor: pointer;
            transition: all 0.3s ease;
            height: 100%;
        }
        .role-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        .role-card.selected {
            border-color: var(--phoenix-primary);
            background-color: rgba(43, 100, 210, 0.05);
        }
        .role-card.selected .card-body {
            border-left: 4px solid var(--phoenix-primary);
        }
        .context-card {
            border: 2px dashed #dee2e6;
            background: #f8f9fa;
            padding: 2rem;
            border-radius: 0.5rem;
            text-align: center;
        }
        .context-card.has-selection {
            border-style: solid;
            border-color: var(--phoenix-primary);
            background: white;
        }
    </style>
}

<page-header title="@ViewData["Title"]" icon-class="fas fa-wrench"></page-header>

<div class="container-fluid">

    <form asp-action="Create" method="post" id="createUserForm">
        @Html.AntiForgeryToken()
        
        <div class="card">
            <div class="card-body">
                <div class="wizard-container">
                    <!-- Step Indicator -->
                    <div class="step-indicator d-none d-md-flex">
                        <div class="step active" data-step="1">
                            <div class="step-number">1</div>
                            <div class="step-label">Información Personal</div>
                        </div>
                        <div class="step" data-step="2">
                            <div class="step-number">2</div>
                            <div class="step-label">Rol y Acceso</div>
                        </div>
                        <div class="step" data-step="3">
                            <div class="step-number">3</div>
                            <div class="step-label">Configuración</div>
                        </div>
                    </div>

                    <!-- Step 1: Personal Information -->
                    <div class="step-content" id="step1">
                        <div class="row g-4">
                            <div class="col-12">
                                <h4 class="mb-3">
                                    <i class="fas fa-user-circle me-2 text-primary"></i>
                                    Información Personal
                                </h4>
                                <p class="text-muted">Ingrese los datos básicos del nuevo usuario</p>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="FirstName" class="form-control" placeholder="Nombre" />
                                    <label asp-for="FirstName">
                                        <i class="fas fa-user me-1"></i> Nombre
                                    </label>
                                    <span asp-validation-for="FirstName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="LastName" class="form-control" placeholder="Apellido" />
                                    <label asp-for="LastName">
                                        <i class="fas fa-user me-1"></i> Apellido
                                    </label>
                                    <span asp-validation-for="LastName" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Email" class="form-control" type="email" placeholder="Correo" />
                                    <label asp-for="Email">
                                        <i class="fas fa-envelope me-1"></i> Correo Electrónico
                                    </label>
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Identification" class="form-control" placeholder="Identificación" />
                                    <label asp-for="Identification">
                                        <i class="fas fa-id-card me-1"></i> Identificación
                                    </label>
                                    <span asp-validation-for="Identification" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Location Section -->
                            <div class="col-12">
                                <h5 class="mb-3 mt-4">
                                    <i class="fas fa-map-marker-alt me-2 text-info"></i>
                                    Ubicación <span class="badge bg-secondary ms-2">Opcional</span>
                                </h5>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="Country" class="form-select" id="country">
                                        <option value="">-- Seleccionar País --</option>
                                        <option value="Costa Rica">Costa Rica</option>
                                        <option value="Nicaragua">Nicaragua</option>
                                        <option value="Panama">Panamá</option>
                                        <option value="Guatemala">Guatemala</option>
                                        <option value="Honduras">Honduras</option>
                                        <option value="El Salvador">El Salvador</option>
                                    </select>
                                    <label asp-for="Country">
                                        <i class="fas fa-globe me-1"></i> País
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Province" class="form-control" placeholder="Provincia" />
                                    <label asp-for="Province">
                                        <i class="fas fa-map me-1"></i> Provincia
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Canton" class="form-control" placeholder="Cantón" />
                                    <label asp-for="Canton">
                                        <i class="fas fa-city me-1"></i> Cantón
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="District" class="form-control" placeholder="Distrito" />
                                    <label asp-for="District">
                                        <i class="fas fa-building me-1"></i> Distrito
                                    </label>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea asp-for="FullAddress" class="form-control" placeholder="Dirección" style="height: 100px"></textarea>
                                    <label asp-for="FullAddress">
                                        <i class="fas fa-home me-1"></i> Dirección Completa
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Role and Access -->
                    <div class="step-content" id="step2" style="display: none;">
                        <div class="row g-4">
                            <div class="col-12">
                                <h4 class="mb-3">
                                    <i class="fas fa-user-shield me-2 text-primary"></i>
                                    Rol y Permisos de Acceso
                                </h4>
                                <p class="text-muted">Seleccione el rol del usuario y configure sus permisos de acceso</p>
                            </div>

                            <!-- Role Selection -->
                            <div class="col-12">
                                <h5 class="mb-3">Seleccionar Rol</h5>
                                <input type="hidden" asp-for="SelectedRole" id="selectedRole" />
                                <span asp-validation-for="SelectedRole" class="text-danger"></span>
                                
                                <div class="row g-3" id="roleCards">
                                    <!-- Role cards will be populated by JavaScript -->
                                </div>
                            </div>

                            <!-- Context Selection (Incubator/Project) -->
                            <div class="col-12 mt-4" id="contextSection" style="display: none;">
                                <h5 class="mb-3">Contexto de Trabajo</h5>
                                
                                <div class="alert alert-info" id="roleContextInfo">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <span id="roleContextMessage"></span>
                                </div>

                                <!-- Incubator Selection -->
                                <div class="mb-3" id="incubatorSection" style="display: none;">
                                    <label asp-for="SelectedIncubatorId" class="form-label">
                                        <i class="fas fa-building me-1"></i> Incubadora
                                        <span id="incubatorRequired" class="text-danger">*</span>
                                    </label>
                                    <select asp-for="SelectedIncubatorId" class="form-select" id="incubatorSelect">
                                        <option value="">-- Seleccione una incubadora --</option>
                                    </select>
                                    <span asp-validation-for="SelectedIncubatorId" class="text-danger"></span>
                                </div>

                                <!-- Project Selection -->
                                <div class="mb-3" id="projectSection" style="display: none;">
                                    <label asp-for="SelectedProjectId" class="form-label">
                                        <i class="fas fa-project-diagram me-1"></i> Proyecto
                                        <span id="projectRequired" class="text-danger">*</span>
                                    </label>
                                    <select asp-for="SelectedProjectId" class="form-select" id="projectSelect" disabled>
                                        <option value="">-- Primero seleccione una incubadora --</option>
                                    </select>
                                    <span asp-validation-for="SelectedProjectId" class="text-danger"></span>
                                </div>

                                <!-- Context Summary -->
                                <div class="context-card" id="contextSummary" style="display: none;">
                                    <h6 class="mb-3">Resumen de Acceso</h6>
                                    <div id="contextSummaryContent"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Step 3: Configuration -->
                    <div class="step-content" id="step3" style="display: none;">
                        <div class="row g-4">
                            <div class="col-12">
                                <h4 class="mb-3">
                                    <i class="fas fa-cog me-2 text-primary"></i>
                                    Configuración de la Cuenta
                                </h4>
                                <p class="text-muted">Configure las opciones de seguridad y notificaciones</p>
                            </div>

                            <!-- Security Settings -->
                            <div class="col-12">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body">
                                        <h5 class="card-title mb-4">
                                            <i class="fas fa-lock me-2 text-warning"></i>
                                            Seguridad
                                        </h5>

                                        <div class="row g-3">
                                            <div class="col-12">
                                                <div class="form-check form-switch mb-3">
                                                    <input asp-for="GenerateTemporaryPassword" class="form-check-input" type="checkbox" id="generateTempPassword" />
                                                    <label asp-for="GenerateTemporaryPassword" class="form-check-label">
                                                        Generar contraseña temporal
                                                    </label>
                                                    <div class="form-text">El sistema generará una contraseña segura y la enviará por correo al usuario</div>
                                                </div>
                                            </div>

                                            <div class="col-md-6" id="passwordField">
                                                <div class="form-floating">
                                                    <input asp-for="Password" class="form-control" type="password" placeholder="Contraseña" />
                                                    <label asp-for="Password">
                                                        <i class="fas fa-key me-1"></i> Contraseña
                                                    </label>
                                                    <span asp-validation-for="Password" class="text-danger"></span>
                                                    <div class="form-text">Mínimo 6 caracteres con mayúscula, minúscula, número y símbolo</div>
                                                </div>
                                            </div>

                                            <div class="col-md-6" id="confirmPasswordField">
                                                <div class="form-floating">
                                                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Confirmar" />
                                                    <label asp-for="ConfirmPassword">
                                                        <i class="fas fa-key me-1"></i> Confirmar Contraseña
                                                    </label>
                                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                                </div>
                                            </div>

                                            <div class="col-12">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailConfirmed" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailConfirmed" class="form-check-label">
                                                        Confirmar email automáticamente
                                                    </label>
                                                    <div class="form-text">El usuario no necesitará confirmar su correo electrónico</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Email Preferences -->
                            <div class="col-12">
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-4">
                                            <h5 class="card-title mb-0">
                                                <i class="fas fa-bell me-2 text-info"></i>
                                                Preferencias de Notificaciones
                                            </h5>
                                            <div>
                                                <button type="button" class="btn btn-sm btn-outline-primary" id="selectAllPreferences">
                                                    <i class="fas fa-check-double"></i> Todas
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary" id="deselectAllPreferences">
                                                    <i class="fas fa-times"></i> Ninguna
                                                </button>
                                            </div>
                                        </div>

                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailPreferences.SystemWelcome" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailPreferences.SystemWelcome" class="form-check-label"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailPreferences.ProjectWelcome" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailPreferences.ProjectWelcome" class="form-check-label"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailPreferences.Approvals" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailPreferences.Approvals" class="form-check-label"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailPreferences.Rejections" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailPreferences.Rejections" class="form-check-label"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailPreferences.Reminders" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailPreferences.Reminders" class="form-check-label"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailPreferences.Announcements" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailPreferences.Announcements" class="form-check-label"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailPreferences.TaskAssignments" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailPreferences.TaskAssignments" class="form-check-label"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailPreferences.FormDeadlines" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailPreferences.FormDeadlines" class="form-check-label"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailPreferences.MentorMessages" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailPreferences.MentorMessages" class="form-check-label"></label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input asp-for="EmailPreferences.Digest" class="form-check-input" type="checkbox" />
                                                    <label asp-for="EmailPreferences.Digest" class="form-check-label"></label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Navigation Buttons -->
                    <div class="d-flex justify-content-between mt-5">
                        <button type="button" class="btn btn-outline-secondary" id="prevBtn" style="display: none;">
                            <i class="fas fa-arrow-left me-2"></i> Anterior
                        </button>
                        <div class="ms-auto d-flex gap-2">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i> Cancelar
                            </a>
                            <button type="button" class="btn btn-primary" id="nextBtn">
                                Siguiente <i class="fas fa-arrow-right ms-2"></i>
                            </button>
                            <button type="submit" class="btn btn-success" id="submitBtn" style="display: none;">
                                <i class="fas fa-check me-2"></i> Crear Usuario
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/coordination/user-create.js"></script>
}