@model LinaSys.Web.Areas.Coordination.Models.UserManagement.BulkImportProgressViewModel
@{
    ViewData["Title"] = "Importación Masiva";
}

<h1 class="h3 mb-4">
    <i class="fas fa-file-import"></i> @ViewData["Title"]
</h1>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Procesando Importación</h5>
            </div>
            <div class="card-body">
                <div class="text-center">
                    <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
                        <span class="visually-hidden">Procesando...</span>
                    </div>
                    <h6>Importando usuarios...</h6>
                    <p class="text-muted">Por favor espere mientras se procesan los @Model.TotalItems usuarios.</p>
                    <p class="text-muted small">Esta operación puede tardar varios minutos. No cierre esta ventana.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-submit the form to process the import
        document.addEventListener('DOMContentLoaded', function() {
            // Create and submit form to process the import
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '@Url.Action("ProcessBulkImport")';

            const operationInput = document.createElement('input');
            operationInput.type = 'hidden';
            operationInput.name = 'operationId';
            operationInput.value = '@Model.OperationId';

            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = '@Html.AntiForgeryToken()'.match(/value="([^"]+)"/)[1];

            form.appendChild(operationInput);
            form.appendChild(tokenInput);
            document.body.appendChild(form);

            // Submit the form - the server will process and redirect when complete
            form.submit();
        });
    </script>
}