@model LinaSys.Web.Areas.Coordination.Models.UserManagement.UserRolesViewModel
@{
    ViewData["Title"] = $"Gestionar Roles - {Model.FullName}";
}

<h1 class="h3 mb-4">
    <i class="fas fa-user-shield"></i> @ViewData["Title"]
</h1>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Información del Usuario</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <strong>Nombre:</strong> @Model.FullName
                    </div>
                    <div class="col-md-6">
                        <strong>Email:</strong> @Model.Email
                    </div>
                </div>

                <form asp-action="ManageRoles" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="FullName" />
                    <input type="hidden" asp-for="Email" />

                    <h6 class="mt-4 mb-3">Roles Disponibles</h6>
                    
                    <div class="row">
                        @for (int i = 0; i < Model.AvailableRoles.Count; i++)
                        {
                            var role = Model.AvailableRoles[i];
                            <div class="col-md-6 mb-3">
                                <div class="form-check">
                                    <input type="hidden" asp-for="AvailableRoles[i].Name" />
                                    <input type="hidden" asp-for="AvailableRoles[i].DisplayName" />
                                    <input type="hidden" asp-for="AvailableRoles[i].Description" />
                                    <input type="hidden" asp-for="AvailableRoles[i].CanModify" />
                                    
                                    @if (role.CanModify)
                                    {
                                        <input class="form-check-input" type="checkbox" 
                                               name="SelectedRoles" 
                                               value="@role.Name" 
                                               id="role_@i"
                                               @(role.IsSelected ? "checked" : "") />
                                    }
                                    else
                                    {
                                        <input class="form-check-input" type="checkbox" 
                                               id="role_@i"
                                               checked disabled />
                                        @if (role.IsSelected)
                                        {
                                            <input type="hidden" name="SelectedRoles" value="@role.Name" />
                                        }
                                    }
                                    
                                    <label class="form-check-label" for="role_@i">
                                        <strong>@role.DisplayName</strong>
                                        @if (!role.CanModify)
                                        {
                                            <span class="badge bg-secondary ms-1">Protegido</span>
                                        }
                                        <br />
                                        <small class="text-muted">@role.Description</small>
                                    </label>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="alert alert-warning mt-3">
                        <i class="fas fa-exclamation-triangle"></i> 
                        <strong>Advertencia:</strong> Cambiar los roles de un usuario puede afectar su acceso al sistema.
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Guardar Cambios
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.UserId" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Roles Actuales</h5>
            </div>
            <div class="card-body">
                @if (Model.CurrentRoles.Any())
                {
                    <ul class="list-group">
                        @foreach (var role in Model.CurrentRoles)
                        {
                            <li class="list-group-item">
                                <i class="fas fa-user-tag"></i> @role
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No hay roles asignados actualmente.</p>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h5 class="mb-0">Información de Roles</h5>
            </div>
            <div class="card-body">
                <p class="small">Los roles determinan qué acciones puede realizar un usuario en el sistema:</p>
                <ul class="small">
                    <li><strong>Emprendedor:</strong> Acceso básico para participantes</li>
                    <li><strong>Mentor/Guía:</strong> Puede revisar y guiar proyectos</li>
                    <li><strong>Coordinador:</strong> Gestiona proyectos y usuarios</li>
                    <li><strong>Administrador:</strong> Control total de la incubadora</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Optional: Add confirmation dialog
        document.querySelector('form').addEventListener('submit', function(e) {
            if (!confirm('¿Está seguro de que desea actualizar los roles de este usuario?')) {
                e.preventDefault();
            }
        });
    </script>
}