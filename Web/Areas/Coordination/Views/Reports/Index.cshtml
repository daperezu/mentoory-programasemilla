@{
    ViewData["Title"] = ViewBag.Title ?? "Reportes";
    Layout = "_DashboardLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard-core.css" />
    <style>
        .report-card {
            transition: all 0.2s ease-in-out;
            cursor: pointer;
        }
        .report-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 2rem rgba(0,0,0,0.15);
        }
        .report-type-badge {
            position: absolute;
            top: 15px;
            right: 15px;
        }
        .template-preview {
            font-size: 0.85rem;
            max-height: 60px;
            overflow: hidden;
        }
        .report-stats {
            background: linear-gradient(135deg, var(--phoenix-primary) 0%, var(--phoenix-info) 100%);
        }
        .stat-number {
            font-size: 2.5rem;
            font-weight: 700;
        }
        .quick-actions .btn {
            border-radius: 10px;
            padding: 15px 20px;
        }
        .recent-reports .list-group-item {
            border-radius: 10px !important;
            margin-bottom: 10px;
            border: 1px solid var(--phoenix-border-color);
        }
        .template-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }
    </style>
}

@* Dashboard Header *@
<div class="dashboard-header mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h3 class="mb-0">Reportes y Análisis</h3>
            <p class="text-muted mb-0">@ViewBag.ProjectName - @ViewBag.IncubatorName</p>
        </div>
        <div class="col-auto">
            <div class="btn-group" role="group">
                <button class="btn btn-phoenix-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createTemplateModal">
                    <span class="fas fa-plus me-1"></span>Nueva Plantilla
                </button>
                <button class="btn btn-outline-phoenix-primary btn-sm" id="refreshReports">
                    <span class="fas fa-sync-alt me-1"></span>Actualizar
                </button>
            </div>
        </div>
    </div>
</div>

@* Statistics Row *@
<div class="row g-3 mb-4">
    @* Total Templates *@
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card h-100 report-stats text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1 text-white-75">Plantillas Disponibles</h5>
                        <h2 class="stat-number text-white mb-0" id="totalTemplates">-</h2>
                    </div>
                    <div>
                        <span class="fas fa-file-alt fa-2x text-white-50"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Reports Generated *@
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1 text-900">Reportes Generados</h5>
                        <h2 class="stat-number text-primary mb-0" id="totalGenerated">-</h2>
                    </div>
                    <div>
                        <span class="fas fa-chart-bar fa-2x text-primary-300"></span>
                    </div>
                </div>
                <p class="fs-10 fw-semi-bold text-500 mb-0">Este mes</p>
            </div>
        </div>
    </div>

    @* Last Generated *@
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1 text-900">Último Reporte</h5>
                        <h6 class="mb-0" id="lastGenerated">-</h6>
                    </div>
                    <div>
                        <span class="fas fa-clock fa-2x text-info-300"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Quick Export *@
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="mb-3 text-900">Exportación Rápida</h5>
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-primary btn-sm" id="quickExportProgress">
                        <span class="fas fa-download me-1"></span>Progreso General
                    </button>
                    <button class="btn btn-outline-success btn-sm" id="quickExportParticipation">
                        <span class="fas fa-users me-1"></span>Participación
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@* Filter Tabs *@
<div class="card mb-4">
    <div class="card-header">
        <ul class="nav nav-tabs card-header-tabs" id="reportTypeTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all-templates" 
                        data-filter="" type="button" role="tab">
                    <span class="fas fa-th-large me-1"></span>Todas
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="progress-tab" data-bs-toggle="tab" data-bs-target="#progress-templates" 
                        data-filter="Progress" type="button" role="tab">
                    <span class="fas fa-chart-line me-1"></span>Progreso
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="completion-tab" data-bs-toggle="tab" data-bs-target="#completion-templates" 
                        data-filter="Completion" type="button" role="tab">
                    <span class="fas fa-check-circle me-1"></span>Finalización
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="participation-tab" data-bs-toggle="tab" data-bs-target="#participation-templates" 
                        data-filter="Participation" type="button" role="tab">
                    <span class="fas fa-users me-1"></span>Participación
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="custom-tab" data-bs-toggle="tab" data-bs-target="#custom-templates" 
                        data-filter="Custom" type="button" role="tab">
                    <span class="fas fa-cog me-1"></span>Personalizados
                </button>
            </li>
        </ul>
    </div>
</div>

@* Templates Gallery *@
<div class="row">
    <div class="col-12">
        <div id="templatesContainer">
            <div class="text-center py-5">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Cargando plantillas...</span>
                </div>
                <p class="mt-2 text-muted">Cargando plantillas de reportes...</p>
            </div>
        </div>
    </div>
</div>

@* Create Template Modal *@
<div class="modal fade" id="createTemplateModal" tabindex="-1" aria-labelledby="createTemplateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createTemplateModalLabel">
                    <span class="fas fa-plus-circle me-2"></span>Nueva Plantilla de Reporte
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createTemplateForm">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label for="templateName" class="form-label">Nombre de la Plantilla</label>
                            <input type="text" class="form-control" id="templateName" name="name" required 
                                   placeholder="ej. Reporte Mensual de Progreso">
                        </div>
                        <div class="col-12">
                            <label for="templateDescription" class="form-label">Descripción</label>
                            <textarea class="form-control" id="templateDescription" name="description" rows="3"
                                      placeholder="Descripción opcional del contenido del reporte"></textarea>
                        </div>
                        <div class="col-12">
                            <label for="templateType" class="form-label">Tipo de Reporte</label>
                            <select class="form-select" id="templateType" name="reportType" required>
                                <option value="">Seleccione un tipo</option>
                                <option value="Progress">Progreso - Seguimiento de avances</option>
                                <option value="Completion">Finalización - Resultados completados</option>
                                <option value="Participation">Participación - Actividad de usuarios</option>
                                <option value="Custom">Personalizado - Configuración avanzada</option>
                            </select>
                        </div>
                        <div class="col-12" id="configurationSection" style="display: none;">
                            <label for="templateConfiguration" class="form-label">Configuración JSON</label>
                            <textarea class="form-control" id="templateConfiguration" name="configurationJson" rows="5"
                                      placeholder='{"filters": [], "columns": [], "aggregations": []}'>{}</textarea>
                            <div class="form-text">Configuración avanzada en formato JSON para reportes personalizados</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <span class="fas fa-save me-1"></span>Crear Plantilla
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Generate Report Modal *@
<div class="modal fade" id="generateReportModal" tabindex="-1" aria-labelledby="generateReportModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="generateReportModalLabel">
                    <span class="fas fa-chart-bar me-2"></span>Generar Reporte
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="generateReportForm">
                <div class="modal-body">
                    <input type="hidden" id="generateTemplateId" name="templateId">
                    <div class="mb-3">
                        <h6 id="selectedTemplateName" class="text-primary">-</h6>
                        <p id="selectedTemplateDescription" class="text-muted">-</p>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label for="startDate" class="form-label">Fecha Inicial</label>
                            <input type="date" class="form-control" id="startDate" name="startDate">
                        </div>
                        <div class="col-6">
                            <label for="endDate" class="form-label">Fecha Final</label>
                            <input type="date" class="form-control" id="endDate" name="endDate">
                        </div>
                    </div>
                    <div class="mt-3">
                        <div class="form-text">
                            <span class="fas fa-info-circle me-1"></span>
                            Si no especifica fechas, se generará un reporte del último mes.
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <span class="fas fa-play me-1"></span>Generar
                    </button>
                    <button type="button" class="btn btn-success" id="generateAndExport">
                        <span class="fas fa-download me-1"></span>Generar y Exportar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/coordination/reports.js"></script>
}