@model LinaSys.Notification.Application.EmailTemplates.Queries.EmailTemplateDto
@{
    ViewData["Title"] = "Detalles de Plantilla";
    ViewData["PageHeader"] = "Detalles de Plantilla";
    ViewData["PageDescription"] = Model.Name;
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Información General</h3>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Clave Única:</dt>
                    <dd class="col-sm-9"><code>@Model.Key</code></dd>

                    <dt class="col-sm-3">Nombre:</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <dt class="col-sm-3">Descripción:</dt>
                        <dd class="col-sm-9">@Model.Description</dd>
                    }

                    @if (!string.IsNullOrEmpty(Model.Category))
                    {
                        <dt class="col-sm-3">Categoría:</dt>
                        <dd class="col-sm-9"><span class="badge bg-info">@Model.Category</span></dd>
                    }

                    <dt class="col-sm-3">Estado:</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Activa</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactiva</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Creada:</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-3">Última Actualización:</dt>
                    <dd class="col-sm-9">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">
                <h3 class="card-title">Contenido de la Plantilla</h3>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label>Asunto:</label>
                    <div class="border rounded p-2 bg-light">
                        <code>@Model.Subject</code>
                    </div>
                </div>

                <div class="form-group mt-3">
                    <label>Cuerpo HTML:</label>
                    <div class="border rounded p-3" style="background-color: #f8f9fa;">
                        <pre><code>@Model.BodyHtml</code></pre>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.BodyText))
                {
                    <div class="form-group mt-3">
                        <label>Cuerpo Texto Plano:</label>
                        <div class="border rounded p-3" style="background-color: #f8f9fa;">
                            <pre>@Model.BodyText</pre>
                        </div>
                    </div>
                }
            </div>
        </div>


        <div class="card-footer">
            <a asp-action="Edit" asp-route-key="@Model.Key" class="btn btn-primary">
                <i class="fas fa-edit"></i> Editar
            </a>
            <a asp-action="Preview" asp-route-key="@Model.Key" class="btn btn-info" target="_blank">
                <i class="fas fa-eye"></i> Vista Previa
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Volver al Listado
            </a>
        </div>
    </div>
</div>