@model LinaSys.Web.Areas.Coordination.Controllers.EditEmailTemplateViewModel
@{
    ViewData["Title"] = "Editar Plantilla de Correo";
    ViewData["PageHeader"] = "Editar Plantilla";
    ViewData["PageDescription"] = $"Modificar plantilla: {Model.Name}";
}

<div class="row">
    <div class="col-12">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Key" />
            
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Información de la Plantilla</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="control-label">Clave Única</label>
                                <input class="form-control" value="@Model.Key" disabled />
                                <small class="form-text text-muted">La clave no se puede modificar</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Name" class="control-label">Nombre <span class="text-danger">*</span></label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Description" class="control-label">Descripción</label>
                                <input asp-for="Description" class="form-control" />
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="IsActive" class="control-label">Estado</label>
                                <select asp-for="IsActive" class="form-control">
                                    <option value="true">Activa</option>
                                    <option value="false">Inactiva</option>
                                </select>
                                <span asp-validation-for="IsActive" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Subject" class="control-label">Asunto del Correo <span class="text-danger">*</span></label>
                        <input asp-for="Subject" class="form-control" />
                        <span asp-validation-for="Subject" class="text-danger"></span>
                        <small class="form-text text-muted">Puede usar variables como {{UserName}}, {{ProjectName}}, etc.</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="BodyHtml" class="control-label">Cuerpo HTML <span class="text-danger">*</span></label>
                        <textarea asp-for="BodyHtml" class="form-control" rows="10" id="bodyHtml"></textarea>
                        <span asp-validation-for="BodyHtml" class="text-danger"></span>
                        <small class="form-text text-muted">Contenido HTML del correo. Use {{NombreVariable}} para variables dinámicas.</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="BodyText" class="control-label">Cuerpo Texto Plano</label>
                        <textarea asp-for="BodyText" class="form-control" rows="6"></textarea>
                        <span asp-validation-for="BodyText" class="text-danger"></span>
                        <small class="form-text text-muted">Versión en texto plano del correo (opcional)</small>
                    </div>
                </div>
            </div>


            <div class="card-footer">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Guardar Cambios
                </button>
                <a asp-action="Preview" asp-route-key="@Model.Key" class="btn btn-info" target="_blank">
                    <i class="fas fa-eye"></i> Vista Previa
                </a>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Add syntax highlighting or editor enhancement here if needed
        });
    </script>
}