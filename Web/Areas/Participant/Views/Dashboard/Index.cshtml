@model DashboardViewModel
@{
    ViewData["Title"] = "Mi Panel de Control";
    ViewData["PageHeader"] = "Panel de Control";
    ViewData["BreadcrumbParent"] = "Inicio";
    ViewData["BreadcrumbActive"] = "Panel de Control";
}

<div class="container-xxl">
    <!-- Welcome Section -->
    <div class="row">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <div class="avatar avatar-xl">
                                <span class="avatar-title bg-primary-subtle text-primary rounded-circle">
                                    <i class="fas fa-user fa-2x"></i>
                                </span>
                            </div>
                        </div>
                        <div class="col">
                            <h3 class="mb-1">¡Bienvenido de nuevo, @Model.UserName!</h3>
                            <p class="text-muted mb-0">Aquí está el resumen de tu actividad y proyectos activos.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row">
        <div class="col-xl-3 col-md-6">
            <div class="card widget-flat">
                <div class="card-body">
                    <div class="float-end">
                        <i class="fas fa-briefcase widget-icon"></i>
                    </div>
                    <h5 class="text-muted fw-normal mt-0" title="Proyectos Activos">Proyectos Activos</h5>
                    <h3 class="mt-3 mb-3">@Model.ActiveProjectsCount</h3>
                    <p class="mb-0 text-muted">
                        <span class="text-success me-2"><i class="fas fa-arrow-up"></i> Activos</span>
                        <span class="text-nowrap">de @Model.Projects.Count total</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card widget-flat">
                <div class="card-body">
                    <div class="float-end">
                        <i class="fas fa-file-alt widget-icon text-warning"></i>
                    </div>
                    <h5 class="text-muted fw-normal mt-0" title="Formularios Pendientes">Formularios Pendientes</h5>
                    <h3 class="mt-3 mb-3 text-warning">@Model.PendingFormsCount</h3>
                    <p class="mb-0 text-muted">
                        @if (Model.PendingForms.Any(f => f.DaysRemaining <= 3))
                        {
                            <span class="text-danger me-2"><i class="fas fa-exclamation-circle"></i> Urgente</span>
                        }
                        else
                        {
                            <span class="text-info me-2"><i class="fas fa-clock"></i> Por completar</span>
                        }
                    </p>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card widget-flat">
                <div class="card-body">
                    <div class="float-end">
                        <i class="fas fa-bell widget-icon text-info"></i>
                    </div>
                    <h5 class="text-muted fw-normal mt-0" title="Notificaciones">Notificaciones</h5>
                    <h3 class="mt-3 mb-3">@Model.UnreadNotificationsCount</h3>
                    <p class="mb-0 text-muted">
                        <span class="text-info me-2"><i class="fas fa-envelope"></i> Sin leer</span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card widget-flat">
                <div class="card-body">
                    <div class="float-end">
                        <i class="fas fa-bullhorn widget-icon text-success"></i>
                    </div>
                    <h5 class="text-muted fw-normal mt-0" title="Convocatorias">Convocatorias Abiertas</h5>
                    <h3 class="mt-3 mb-3 text-success">@Model.OpenConvocations.Count(c => c.IsOpen)</h3>
                    <p class="mb-0 text-muted">
                        <span class="text-success me-2"><i class="fas fa-door-open"></i> Disponibles</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Forms Alert Section -->
    @if (Model.PendingForms.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <h4 class="alert-heading">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Formularios Pendientes
                    </h4>
                    <p>Tienes formularios que requieren tu atención:</p>
                    <div class="row g-2">
                        @foreach (var form in Model.PendingForms.Take(3))
                        {
                            <div class="col-md-4">
                                <div class="border rounded p-2 bg-white">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1">@form.FormName</h6>
                                            <small class="text-muted">@form.ProjectName</small>
                                        </div>
                                        <div class="text-end">
                                            @if (form.DaysRemaining <= 0)
                                            {
                                                <span class="badge bg-danger">Vencido</span>
                                            }
                                            else if (form.DaysRemaining <= 3)
                                            {
                                                <span class="badge bg-warning">@form.DaysRemaining días</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@form.DaysRemaining días</span>
                                            }
                                            <div>
                                                <a href="@form.FormUrl" class="btn btn-sm btn-primary mt-1">Completar</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    @if (Model.PendingForms.Count > 3)
                    {
                        <hr>
                        <p class="mb-0">
                            <a href="@Url.Action("PendingForms")" class="alert-link">Ver todos los formularios pendientes (@Model.PendingForms.Count)</a>
                        </p>
                    }
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <!-- Main Content Row -->
    <div class="row">
        <!-- Projects Section -->
        <div class="col-xl-8">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="header-title mb-0">Mis Proyectos</h4>
                        <a href="@Url.Action("MyProjects")" class="btn btn-sm btn-primary">
                            Ver todos <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.Projects.Any())
                    {
                        <div class="row g-3">
                            @foreach (var project in Model.Projects.Take(4))
                            {
                                <div class="col-md-6">
                                    <div class="card project-card h-100">
                                        <div class="card-body">
                                            <div class="d-flex align-items-start mb-3">
                                                <img src="@project.ImageUrl" alt="@project.ProjectName" class="rounded-circle avatar-md me-3">
                                                <div class="flex-grow-1">
                                                    <h5 class="mt-0 mb-1">@project.ProjectName</h5>
                                                    <span class="badge bg-@(project.StatusColor) mb-2">@project.Status</span>
                                                </div>
                                            </div>
                                            
                                            <p class="text-muted mb-2 text-truncate-2">@project.Description</p>
                                            
                                            <div class="mb-3">
                                                <div class="d-flex justify-content-between mb-1">
                                                    <small class="text-muted">Progreso</small>
                                                    <small class="text-muted">@project.Progress%</small>
                                                </div>
                                                <div class="progress" style="height: 6px;">
                                                    <div class="progress-bar bg-success" role="progressbar" 
                                                         style="width: @(project.Progress)%" 
                                                         aria-valuenow="@project.Progress" 
                                                         aria-valuemin="0" 
                                                         aria-valuemax="100">
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row text-center">
                                                <div class="col-6">
                                                    <p class="text-muted mb-1 font-13">Etapa Actual</p>
                                                    <h6 class="fw-normal">@project.CurrentStage</h6>
                                                </div>
                                                <div class="col-6">
                                                    <p class="text-muted mb-1 font-13">Mentor</p>
                                                    <h6 class="fw-normal">@project.MentorName</h6>
                                                </div>
                                            </div>

                                            <div class="mt-3 pt-3 border-top">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <small class="text-muted">
                                                        <i class="far fa-calendar me-1"></i>
                                                        Iniciado: @project.StartDate.ToString("dd/MM/yyyy")
                                                    </small>
                                                    <a href="#" class="btn btn-sm btn-light">Ver detalles</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No tienes proyectos activos</h5>
                            <p class="text-muted">Explora las convocatorias abiertas para unirte a un proyecto.</p>
                            <a href="@Url.Action("OpenConvocations")" class="btn btn-primary">
                                Ver Convocatorias
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Open Convocations -->
            @if (Model.OpenConvocations.Any(c => c.IsOpen))
            {
                <div class="card">
                    <div class="card-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <h4 class="header-title mb-0">Convocatorias Abiertas</h4>
                            <a href="@Url.Action("OpenConvocations")" class="btn btn-sm btn-success">
                                Ver todas <i class="fas fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            @foreach (var convocation in Model.OpenConvocations.Where(c => c.IsOpen).Take(2))
                            {
                                <div class="col-12">
                                    <div class="card border">
                                        <div class="card-body">
                                            <div class="row align-items-center">
                                                <div class="col-md-8">
                                                    <h5 class="mb-2">@convocation.Title</h5>
                                                    <p class="text-muted mb-2">@convocation.Description</p>
                                                    <div class="d-flex gap-3">
                                                        <small class="text-muted">
                                                            <i class="fas fa-building me-1"></i> @convocation.IncubatorName
                                                        </small>
                                                        <small class="text-muted">
                                                            <i class="far fa-clock me-1"></i> Cierra en @convocation.DaysRemaining días
                                                        </small>
                                                    </div>
                                                </div>
                                                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                                    <span class="badge bg-success mb-2">Abierta</span>
                                                    <div>
                                                        <a href="@convocation.ApplyUrl" class="btn btn-primary">
                                                            Aplicar ahora
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Activity Timeline Section -->
        <div class="col-xl-4">
            <div class="card">
                <div class="card-header">
                    <h4 class="header-title mb-0">Actividad Reciente</h4>
                </div>
                <div class="card-body">
                    @if (Model.RecentActivities.Any())
                    {
                        <div class="timeline-alt pb-0">
                            @foreach (var activity in Model.RecentActivities.Take(10))
                            {
                                <div class="timeline-item">
                                    <i class="@activity.Icon bg-@(activity.IconColor)-lighten text-@(activity.IconColor) timeline-icon"></i>
                                    <div class="timeline-item-info">
                                        <a href="@activity.RelatedEntityUrl" class="text-@(activity.IconColor) fw-bold mb-1 d-block">
                                            @activity.Category
                                        </a>
                                        <small>@activity.Description</small>
                                        <p class="mb-0 pb-2">
                                            <small class="text-muted">@activity.Timestamp.ToString("dd MMM yyyy HH:mm")</small>
                                        </p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-history fa-2x text-muted mb-2"></i>
                            <p class="text-muted">No hay actividad reciente</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card">
                <div class="card-header">
                    <h4 class="header-title mb-0">Acciones Rápidas</h4>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        @if (Model.PendingForms.Any())
                        {
                            <a href="@Url.Action("PendingForms")" class="btn btn-warning">
                                <i class="fas fa-file-alt me-2"></i> Completar Formularios Pendientes
                            </a>
                        }
                        <a href="@Url.Action("MyProjects")" class="btn btn-info">
                            <i class="fas fa-briefcase me-2"></i> Ver Mis Proyectos
                        </a>
                        <a href="@Url.Action("OpenConvocations")" class="btn btn-success">
                            <i class="fas fa-bullhorn me-2"></i> Explorar Convocatorias
                        </a>
                        <a href="#" class="btn btn-secondary">
                            <i class="fas fa-user-cog me-2"></i> Configurar Preferencias
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .text-truncate-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        .project-card {
            transition: transform 0.2s;
            border: 1px solid #e3e6f0;
        }
        
        .project-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        
        .timeline-alt {
            padding: 20px 0;
        }
        
        .timeline-item {
            position: relative;
            padding-left: 40px;
            padding-bottom: 20px;
        }
        
        .timeline-item:before {
            content: "";
            position: absolute;
            left: 15px;
            top: 30px;
            height: 100%;
            border-left: 2px solid #e3e6f0;
        }
        
        .timeline-item:last-child:before {
            display: none;
        }
        
        .timeline-icon {
            position: absolute;
            left: 0;
            top: 0;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            border: 2px solid;
        }
        
        .widget-icon {
            font-size: 2rem;
            opacity: 0.3;
        }
        
        .widget-flat {
            position: relative;
            overflow: hidden;
        }
        
        .widget-flat:after {
            content: "";
            position: absolute;
            top: 0;
            right: 0;
            width: 60%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1));
        }
    </style>
}

@section Scripts {
    <script>
        // Auto-refresh pending forms countdown every minute
        setInterval(function() {
            location.reload();
        }, 60000);
    </script>
}