@model LinaSys.Web.ViewComponents.UserContextDisplayViewModel

<a href="/ContextSelection" class="nav-link context-display px-2 py-1" 
   data-bs-toggle="tooltip" 
   data-bs-placement="bottom" 
   title="Haz clic para cambiar contexto">
    <div class="d-flex align-items-center">
        @if (Model.HasContext)
        {
            @if (!string.IsNullOrEmpty(Model.Role))
            {
                <span class="badge bg-primary-subtle text-primary me-1">
                    <i class="fas fa-user-tag me-1 d-none d-lg-inline"></i>
                    @Model.Role
                </span>
            }
            
            @if (Model.ShowIncubator && !string.IsNullOrEmpty(Model.IncubatorName))
            {
                <span class="text-body-tertiary mx-1 d-none d-md-inline">|</span>
                <span class="badge bg-info-subtle text-info me-1 d-none d-md-inline">
                    <i class="fas fa-building me-1 d-none d-lg-inline"></i>
                    <span class="text-truncate">@Model.IncubatorName</span>
                </span>
            }
            
            @if (Model.ShowProject && !string.IsNullOrEmpty(Model.ProjectName))
            {
                <span class="text-body-tertiary mx-1 d-none d-md-inline">|</span>
                <span class="badge bg-success-subtle text-success d-none d-md-inline">
                    <i class="fas fa-project-diagram me-1 d-none d-lg-inline"></i>
                    <span class="text-truncate">@Model.ProjectName</span>
                </span>
            }
        }
        else
        {
            <span class="badge bg-warning-subtle text-warning">
                <i class="fas fa-exclamation-triangle me-1"></i>
                <span class="d-none d-sm-inline">Seleccionar contexto</span>
                <span class="d-inline d-sm-none">Contexto</span>
            </span>
        }
    </div>
</a>

<style>
    .context-display {
        transition: background-color 0.2s ease;
        border-radius: 0.375rem;
    }
    
    .context-display:hover {
        background-color: var(--phoenix-gray-100);
    }
    
    .dark .context-display:hover {
        background-color: var(--phoenix-gray-800);
    }
    
    .context-display .badge {
        font-size: 0.75rem;
        padding: 0.25rem 0.5rem;
        font-weight: 500;
    }
    
    .context-display .text-truncate {
        max-width: 120px;
        display: inline-block;
        vertical-align: middle;
    }
    
    @@media (max-width: 992px) {
        .context-display .text-truncate {
            max-width: 80px;
        }
    }
    
    @@media (max-width: 768px) {
        .context-display .badge {
            font-size: 0.7rem;
            padding: 0.2rem 0.4rem;
        }
    }
</style>