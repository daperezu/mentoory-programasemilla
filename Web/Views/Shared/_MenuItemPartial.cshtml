@using LinaSys.Core.Application.Navigation.Queries
@model NavigationMenuItemDto

@{
    var isActive = IsActiveMenuItem(Model);
    var hasChildren = Model.Children != null && Model.Children.Any();
}

@if (hasChildren)
{
    @* Parent pages with children - matches Phoenix template structure *@
    <div class="nav-item-wrapper">
        <a class="nav-link dropdown-indicator label-1 @(Model.CssClass) @(isActive ? "active" : "")" 
           href="#nv-@Model.Id" 
           role="button" 
           data-bs-toggle="collapse" 
           aria-expanded="@(isActive ? "true" : "false")" 
           aria-controls="nv-@Model.Id">
            <div class="d-flex align-items-center">
                <div class="dropdown-indicator-icon-wrapper">
                    <span class="fas fa-caret-right dropdown-indicator-icon"></span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Icon))
                {
                    @if (Model.Icon.StartsWith("fa"))
                    {
                        <span class="nav-link-icon"><i class="@Model.Icon"></i></span>
                    }
                    else
                    {
                        <span class="nav-link-icon"><span data-feather="@Model.Icon"></span></span>
                    }
                }
                <span class="nav-link-text">@Model.DisplayText</span>
            </div>
        </a>
        <div class="parent-wrapper label-1">
            <ul class="nav collapse parent @(isActive ? "show" : "")" data-bs-parent="#navbarVerticalCollapse" id="nv-@Model.Id">
                <li class="collapsed-nav-item-title d-none">@Model.DisplayText</li>
                @foreach (var child in Model.Children!)
                {
                    <li class="nav-item">
                        @if (child.Children != null && child.Children.Any())
                        {
                            @* Nested dropdown indicator for sub-menus *@
                            <a class="nav-link dropdown-indicator @(child.CssClass)" 
                               href="#nv-@child.Id" 
                               data-bs-toggle="collapse" 
                               aria-expanded="@(IsActiveMenuItem(child) ? "true" : "false")" 
                               aria-controls="nv-@child.Id">
                                <div class="d-flex align-items-center">
                                    <div class="dropdown-indicator-icon-wrapper">
                                        <span class="fas fa-caret-right dropdown-indicator-icon"></span>
                                    </div>
                                    <span class="nav-link-text">@child.DisplayText</span>
                                </div>
                            </a>
                            @* Nested parent wrapper *@
                            <div class="parent-wrapper">
                                <ul class="nav collapse parent @(IsActiveMenuItem(child) ? "show" : "")" 
                                    data-bs-parent="#nv-@Model.Id" 
                                    id="nv-@child.Id">
                                    @foreach (var grandchild in child.Children)
                                    {
                                        <li class="nav-item">
                                            <a class="nav-link @(grandchild.CssClass) @(IsActiveUrl(grandchild.Url) ? "active" : "")" 
                                               href="@grandchild.Url">
                                                <div class="d-flex align-items-center">
                                                    <span class="nav-link-text">@grandchild.DisplayText</span>
                                                </div>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                        else
                        {
                            @* Simple child item without sub-children *@
                            <a class="nav-link @(child.CssClass) @(IsActiveUrl(child.Url) ? "active" : "")" 
                               href="@child.Url">
                                <div class="d-flex align-items-center">
                                    <span class="nav-link-text">@child.DisplayText</span>
                                </div>
                            </a>
                        }
                    </li>
                }
            </ul>
        </div>
    </div>
}
else if (!Model.IsSection)
{
    @* Simple navigation item without children - matches Phoenix template *@
    <div class="nav-item-wrapper">
        <a class="nav-link label-1 @(Model.CssClass) @(IsActiveUrl(Model.Url) ? "active" : "")" 
           href="@Model.Url" 
           role="button">
            <div class="d-flex align-items-center">
                @if (!string.IsNullOrEmpty(Model.Icon))
                {
                    @if (Model.Icon.StartsWith("fa"))
                    {
                        <span class="nav-link-icon"><i class="@Model.Icon"></i></span>
                    }
                    else
                    {
                        <span class="nav-link-icon"><span data-feather="@Model.Icon"></span></span>
                    }
                }
                <span class="nav-link-text-wrapper"><span class="nav-link-text">@Model.DisplayText</span></span>
            </div>
        </a>
    </div>
}

@functions {
    private bool IsActiveMenuItem(NavigationMenuItemDto item)
    {
        if (item.Children != null && item.Children.Any())
        {
            return item.Children.Any(child => IsActiveMenuItem(child));
        }
        
        return IsActiveUrl(item.Url);
    }
    
    private bool IsActiveUrl(string url)
    {
        if (string.IsNullOrEmpty(url) || url == "#")
        {
            return false;
        }
        
        var currentPath = Context.Request.Path.Value;
        if (string.IsNullOrEmpty(currentPath))
        {
            return false;
        }
        
        // Check if the current path starts with the menu item's URL
        return currentPath.StartsWith(url, StringComparison.OrdinalIgnoreCase);
    }
}