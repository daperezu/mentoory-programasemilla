@{
    ViewData["Title"] = "Invitación No Encontrada";
    Layout = "_HeadlessLayout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body text-center p-5">
                    <i class="fas fa-exclamation-triangle text-warning" style="font-size: 4rem;"></i>
                    <h3 class="mt-3">Invitación No Encontrada</h3>
                    <p class="text-muted">
                        La invitación que estás buscando no existe o el enlace puede estar dañado.
                    </p>
                    <p class="text-muted">
                        Por favor, verifica el enlace en tu email o contacta al administrador del proyecto.
                    </p>
                    <div class="mt-4">
                        <a href="/" class="btn btn-primary">
                            <i class="fas fa-home"></i> Ir al Inicio
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>