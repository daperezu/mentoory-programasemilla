@{
    ViewData["Title"] = "Invitación Rechazada";
    Layout = "_HeadlessLayout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body text-center p-5">
                    <i class="fas fa-times-circle text-warning" style="font-size: 4rem;"></i>
                    <h3 class="mt-3">Invitación Rechazada</h3>
                    <p class="text-muted">
                        Has rechazado exitosamente la invitación al proyecto.
                    </p>
                    <p class="text-muted">
                        Si cambias de opinión en el futuro, puedes contactar al administrador del proyecto 
                        para solicitar una nueva invitación.
                    </p>
                    <div class="mt-4">
                        <a href="/" class="btn btn-primary">
                            <i class="fas fa-home"></i> Ir al Inicio
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>